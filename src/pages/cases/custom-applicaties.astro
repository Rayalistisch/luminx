---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CasePage from "../../components/CasePage.astro";
---

<BaseLayout
  title="Case: Custom Applicatie voor Afspraakbeheer | LuminX"
  description="Een maatwerk applicatie voor afspraakbeheer die planning en operationele workflow sterk verbeterde."
>
  <CasePage
    title="Custom applicatie voor afspraakbeheer"
    client="Serviceorganisatie"
    sector="Operations"
    intro="We ontwikkelden een maatwerk webapp die het volledige afspraakbeheer centraliseert. Hierdoor kreeg het team realtime overzicht, minder handmatig werk en minder fouten in de planning."
    imageSrc="/images/reservaxactifaid.png"
    imageAlt="Screenshot van de custom applicatie"
    services={[
      "(Web)app Development",
      "Procesautomation",
      "Integraties"
    ]}
    challenge={[
      "Planning werd verspreid over losse tools en handmatige lijsten",
      "Veel tijdverlies door dubbel invoerwerk en afstemming",
      "Gebrek aan realtime status van afspraken en capaciteit",
      "Hoge foutgevoeligheid bij wijzigingen en no-shows"
    ]}
    approach={[
      "Procesmapping van intake tot uitvoering en terugkoppeling",
      "Ontwerp van een taakgerichte interface voor planners en uitvoerders",
      "Bouw van modules voor planning, notificaties en statusupdates",
      "Koppeling met bestaande databronnen en uitrol per team"
    ]}
    results={[
      "Eenduidige planning en inzicht voor alle betrokken teams",
      "Minder handmatige handelingen in de dagelijkse operatie",
      "Snellere afhandeling van wijzigingen en uitzonderingen",
      "Betere voorspelbaarheid van bezetting en doorlooptijd"
    ]}
    metrics={[
      { value: "-46%", label: "Minder handmatig werk" },
      { value: "+31%", label: "Snellere afhandeling" },
      { value: "Realtime", label: "Operationeel inzicht" }
    ]}
    gallery={[
      { src: "/images/Reservax1.png", alt: "Reservax dashboard overzicht", title: "Reserveer auto's", desc: "Medewerkers reserveren een beschikbare auto in een paar tikken — geen dubbele boekingen, geen e-mails." },
      { src: "/images/Reservax2.png", alt: "Reservax planning module", title: "Vergaderruimte reservering", desc: "Vergaderruimtes in één overzicht. Beschikbaarheid direct zichtbaar, reservering bevestigd in seconden." },
      { src: "/images/Reservax3.png", alt: "Reservax statusupdates", title: "Alles in 1 app", desc: "Auto's, ruimtes en middelen centraal beheerd. Eén app voor het hele team, zonder losse systemen." },
      { src: "/images/Reservax4.png", alt: "Reservax notificaties", title: "Duidelijk voor het team", desc: "Iedereen ziet wat beschikbaar is en wie wat gebruikt. Geen verwarring, geen dubbel werk." },
      { src: "/images/Reservax5.png", alt: "Reservax rapportage", title: "Actueel en live", desc: "Alle reserveringen worden direct verwerkt. Het overzicht klopt altijd, ook als er iets wijzigt." },
    ]}
  />
</BaseLayout>
