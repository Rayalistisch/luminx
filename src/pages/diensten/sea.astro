---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import ContactOverlay from "../../components/ContactOverlay.astro";

const siteOrigin = Astro.site?.toString() ?? "https://luminx.nl";
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "SEA – Google Ads",
  description: "Google Ads campagnes die op het juiste moment zichtbaar zijn, gericht op conversie en een sterke ROAS.",
  serviceType: "Search Engine Advertising",
  url: canonicalUrl,
  areaServed: "NL",
  provider: {
    "@type": "Organization",
    "@id": `${siteOrigin}/#organization`,
    name: "LUMINX",
    url: siteOrigin,
  },
};

const campaignTypes = [
  {
    icon: "◈",
    title: "Google Search Ads",
    description: "Tekstadvertenties bovenaan de zoekresultaten bij relevante zoekopdrachten. Bereikt gebruikers met hoge koopintentie en genereert directe conversies.",
  },
  {
    icon: "◉",
    title: "Google Shopping",
    description: "Productadvertenties met afbeelding, prijs en titel direct in de zoekresultaten. Het meest effectieve campagnetype voor e-commerce en productgerichte bedrijven.",
  },
  {
    icon: "◎",
    title: "Display & Remarketing",
    description: "Visuele advertenties op het Google Display Netwerk. Display vergroot merkbekendheid; remarketing heractivert eerdere bezoekers met gepersonaliseerde boodschappen.",
  },
  {
    icon: "◌",
    title: "Performance Max",
    description: "AI-gestuurd campagnetype dat automatisch het optimale kanaal, format en biedstrategie selecteert. Levert doorgaans de hoogste conversie-output binnen het Google Ads ecosysteem.",
  },
  {
    icon: "✦",
    title: "YouTube Ads",
    description: "Videoadvertenties vóór en tijdens YouTube-content. Effectief voor merkbekendheid en overweging, met volledig meetbare resultaten op weergave- en conversieniveau.",
  },
  {
    icon: "●",
    title: "Microsoft Advertising",
    description: "Aanvullend zoeknetwerk via Bing, Yahoo en DuckDuckGo. Kenmerkt zich door lagere CPC's en minder concurrentie, met een doorgaans hoger converterend zakelijk publiek.",
  },
];

const benefits = [
  {
    title: "Direct resultaat zonder leercurve",
    body: "Een ervaren SEA-specialist beschikt over kennis uit honderden campagnes. Die ervaring vertaalt zich naar snellere resultaten en minder budgetverlies in de opstartfase.",
  },
  {
    title: "Toegang tot professionele tooling",
    body: "Professioneel SEA-beheer omvat tooling als SEMrush, Google Keyword Planner, Search Ads 360 en geavanceerde biedalgoritmen. Voor individuele bedrijven zijn deze tools zelden rendabel om zelfstandig aan te schaffen.",
  },
  {
    title: "Continu bijgesteld op data",
    body: "SEA vereist doorlopende aandacht. Dagelijkse monitoring, wekelijkse optimalisatie en maandelijkse strategische evaluatie zijn noodzakelijk om het rendement structureel te verbeteren.",
  },
  {
    title: "Volledige transparantie en eigenaarschap",
    body: "Bij professioneel beheer behoudt de opdrachtgever volledige toegang tot het eigen Google Ads-account. Rapportage over kosten, conversies en ROAS is helder, zonder verborgen marges op het advertentiebudget.",
  },
  {
    title: "Schaalbaar zonder extra overhead",
    body: "SEA schaalt mee met de organisatie. Uitbreiding naar nieuwe producten, regio's of hogere budgetten vereist geen extra personeel, enkel strategische aanpassingen in de campagnestructuur.",
  },
];

const faq = [
  {
    q: "Wat doet een SEA specialist precies?",
    a: "Een SEA specialist beheert betaalde advertentiecampagnes via platformen als Google Ads en Microsoft Advertising. Dat omvat zoekwoordonderzoek, campagne-opzet, advertentieteksten schrijven, biedstrategieën instellen en dagelijkse optimalisatie op basis van data. Het doel is altijd hetzelfde: zo veel mogelijk resultaat halen uit elk advertentie-euro.",
  },
  {
    q: "Wat kost Google Ads beheer?",
    a: "De kosten bestaan uit twee onderdelen: het advertentiebudget dat rechtstreeks naar Google gaat, en de beheervergoeding aan LuminX. De beheervergoeding is afhankelijk van de campagnecomplexiteit en het maandbudget. We werken altijd met een helder voorstel zodat je precies weet wat je betaalt — en wat je terugkrijgt.",
  },
  {
    q: "Hoe snel zie ik resultaat met SEA?",
    a: "Dat is één van de grootste voordelen van SEA ten opzichte van SEO: resultaat is snel zichtbaar. Zodra een campagne live gaat, kunnen eerste klikken en conversies al op dag één binnenkomen. De eerste twee tot vier weken gebruiken we voor optimalisatie. Na acht tot twaalf weken zijn we in staat om op basis van data consistente prognoses te maken.",
  },
  {
    q: "Wat is het verschil tussen SEO en SEA?",
    a: "SEO richt zich op organische (gratis) posities in Google via techniek, content en linkbuilding. Dat kost tijd maar heeft een duurzame impact. SEA werkt met betaalde advertenties die direct bovenaan de zoekresultaten verschijnen. Ideaal voor snelle resultaten, seizoensacties of terwijl je SEO nog wordt opgebouwd. De meeste bedrijven profiteren van een combinatie van beide.",
  },
  {
    q: "Behouden we toegang tot ons eigen Google Ads account?",
    a: "Altijd. We werken in jouw eigen Google Ads account, nooit in een gedeeld agentschapsaccount. Volledige transparantie en eigenaarschap staan bij ons centraal. Als de samenwerking ooit eindigt, neem jij het account gewoon mee.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<BaseLayout
  title="SEA Uitbesteden – Google Ads Specialist | LuminX"
  description="Google Ads campagnes die op het juiste moment zichtbaar zijn, gericht op conversie en een sterke ROAS. Professioneel SEA beheer door LuminX."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <div class="cursor"></div>
  <div class="cursor-follower"></div>
  <Nav basePath="/" />

  <main class="sea-page">

    <!-- Hero -->
    <section class="sea-hero" data-bg-color="#0A0A0A">
      <div class="sea-hero-overlay" aria-hidden="true"></div>
      <div class="sea-hero-inner">
        <div class="sea-hero-content">
          <a href="/diensten/online-marketing" class="sea-back-link">← Online Marketing</a>
          <span class="sea-kicker">Specialisme</span>
          <h1><span class="sea-icon" aria-hidden="true">◈</span> SEA</h1>
          <p class="sea-intro-p">Betaald zoeken is een precisiemiddel: de juiste boodschap, op het juiste moment, voor de juiste doelgroep, met elke euro verantwoord.</p>
          <div class="sea-actions">
            <a href="#contact" class="sea-btn-primary">Plan kennismaking</a>
            <a href="#aanpak" class="sea-btn-secondary">Bekijk aanpak</a>
          </div>
          <div class="sea-metrics">
            <article class="sea-metric">
              <strong>4–8×</strong>
              <span>Gemiddelde ROAS</span>
            </article>
            <article class="sea-metric">
              <strong>−20–40%</strong>
              <span>Lagere kosten per lead</span>
            </article>
            <article class="sea-metric">
              <strong>2–4 wkn</strong>
              <span>Eerste campagne live</span>
            </article>
          </div>
        </div>
        <aside class="sea-hero-panel">
          <span>Meetbare uitkomsten</span>
          <ul>
            <li>Lagere kosten per acquisitie bij hogere leadkwaliteit</li>
            <li>Volledige transparantie via realtime dashboarding</li>
            <li>Minder budgetverspilling door nauwkeurige doelgroepsegmentatie</li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- Intro: wat is SEA -->
    <section class="sea-what" data-bg-color="#FEFEFE">
      <div class="sea-container sea-what-grid">
        <div class="sea-what-text">
          <span class="sea-label">Wat is SEA?</span>
          <h2>Search Engine Advertising: betaalde zichtbaarheid in zoekmachines</h2>
          <p>Search Engine Advertising (SEA) is het plaatsen van betaalde advertenties in zoekmachines zoals Google en Bing. Adverteerders betalen per klik (CPC) en verschijnen direct bovenaan de zoekresultaten, vóór organische posities, op exact de zoektermen die relevant zijn voor hun doelgroep.</p>
          <p>Waar SEO maanden nodig heeft om posities op te bouwen, levert SEA directe zichtbaarheid. Dat maakt het bij uitstek geschikt voor leadgeneratie, het valideren van nieuwe markten en het ondersteunen van seizoensgebonden campagnes. Structureel geoptimaliseerd SEA-beheer vormt een voorspelbare groeimotor met meetbaar rendement.</p>
          <a href="#contact" class="sea-inline-cta" data-overlay-open>Gratis adviesgesprek →</a>
        </div>
        <div class="sea-what-visual" aria-hidden="true">
          <div class="sea-stat-stack">
            <div class="sea-stat-stack-header">
              <span class="sea-stat-dot"></span>
              <span>SEA Resultaten</span>
            </div>
            <div class="sea-stat-item">
              <span class="sea-stat-num">01</span>
              <div class="sea-stat-body">
                <span class="sea-stat-value">4–8×</span>
                <span class="sea-stat-desc">Gemiddelde ROAS</span>
              </div>
            </div>
            <div class="sea-stat-item">
              <span class="sea-stat-num">02</span>
              <div class="sea-stat-body">
                <span class="sea-stat-value">−40%</span>
                <span class="sea-stat-desc">Lagere kosten per lead</span>
              </div>
            </div>
            <div class="sea-stat-item">
              <span class="sea-stat-num">03</span>
              <div class="sea-stat-body">
                <span class="sea-stat-value">vanaf dag 1</span>
                <span class="sea-stat-desc">Eerste klikken</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Campagnetypes / Services -->
    <section class="sea-services" data-bg-color="#F7F9FC">
      <div class="sea-container">
        <div class="sea-section-head centered">
          <span class="sea-label">Campagnetypes</span>
          <h2>Het Google Ads ecosysteem in zes campagneformats</h2>
          <p>Elk campagnetype bedient een ander moment in de klantreis. Effectief SEA-beheer combineert deze formats tot een samenhangende strategie met maximale dekking.</p>
        </div>
        <div class="sea-cards-grid">
          {campaignTypes.map((type) => (
            <div class="sea-card">
              <div class="sea-card-icon" aria-hidden="true">{type.icon}</div>
              <h3>{type.title}</h3>
              <p>{type.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Voordelen: tekst links + accordion rechts -->
    <section class="sea-benefits" data-bg-color="#FEFEFE">
      <div class="sea-container sea-benefits-grid">
        <div class="sea-benefits-left">
          <span class="sea-label">Waarom uitbesteden?</span>
          <h2>De impact van professioneel SEA-beheer</h2>
          <p>Google Ads is een vakgebied op zich. De interface verandert continu, biedstrategieën worden complexer en de concurrentie neemt toe. Professioneel beheer levert structureel betere resultaten dan intern management zonder dedicated expertise.</p>
          <div class="sea-benefit-stats">
            <div class="sea-bstat">
              <strong>95%</strong>
              <span>van onze klanten ziet binnen 60 dagen resultaatstijging</span>
            </div>
            <div class="sea-bstat">
              <strong>100%</strong>
              <span>accounteigenaarschap bij de klant</span>
            </div>
          </div>
        </div>
        <div class="sea-benefits-right">
          {benefits.map((b) => (
            <details class="sea-benefit-item">
              <summary>{b.title}</summary>
              <p>{b.body}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Aanpak / Process -->
    <section class="sea-approach" id="aanpak" data-bg-color="#F7F9FC">
      <div class="sea-container">
        <div class="sea-section-head">
          <span class="sea-label">Aanpak</span>
          <h2>Vier fases van analyse naar winstgevende campagnes.</h2>
        </div>
        <div class="sea-steps">
          <article class="sea-step">
            <span class="sea-step-num">01</span>
            <h3>Audit & strategie</h3>
            <p>Het bestaande account wordt geanalyseerd (of vanaf nul opgebouwd). Zoekwoordonderzoek, concurrentieanalyse en het vaststellen van doelstellingen, KPI's en budgetallocatie vormen de basis.</p>
          </article>
          <article class="sea-step">
            <span class="sea-step-num">02</span>
            <h3>Opzet & creatie</h3>
            <p>De campagnestructuur wordt opgebouwd, advertentieteksten geschreven, conversietracking via GTM en GA4 geinstalleerd, en remarketingdoelgroepen ingericht.</p>
          </article>
          <article class="sea-step">
            <span class="sea-step-num">03</span>
            <h3>Livegang & monitoring</h3>
            <p>Na livegang volgt dagelijkse monitoring op kwaliteitsscore, impressieshare, CTR en conversies. Snel bijsturen in de eerste weken is cruciaal voor campagnesucces.</p>
          </article>
          <article class="sea-step">
            <span class="sea-step-num">04</span>
            <h3>Optimalisatie & schaling</h3>
            <p>Op basis van data worden biedstrategieën geoptimaliseerd, verliesgevende zoekwoorden uitgesloten, nieuwe advertentieformats getest en bewezen campagnes opgeschaald.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Pijnpunten vs oplossingen -->
    <section class="sea-context" data-bg-color="#FEFEFE">
      <div class="sea-container sea-context-grid">
        <article class="sea-block">
          <h2>Veelvoorkomende knelpunten bij SEA</h2>
          <ul class="sea-list sea-list--muted">
            <li>Advertentiebudget verdwijnt zonder aantoonbaar rendement</li>
            <li>Campagnes draaien te breed, zonder focus op de juiste doelgroepsegmenten</li>
            <li>Zwakke aansluiting tussen advertentie, zoekwoord en landingspagina</li>
            <li>Ontbrekende structurele optimalisatie op basis van data en conversies</li>
            <li>Geen inzicht in welke campagnes daadwerkelijk omzet genereren</li>
            <li>Onoverzichtelijke accountstructuur die bijsturing bemoeilijkt</li>
          </ul>
        </article>
        <article class="sea-block sea-block--soft">
          <h2>Wat professioneel SEA-beheer oplevert</h2>
          <ul class="sea-list">
            <li>Campagnestructuur gebaseerd op zoekintentie en fase in de klantreis</li>
            <li>Geoptimaliseerde advertentieteksten met doorlopende A/B-tests voor hogere CTR</li>
            <li>Conversiegerichte landingspagina-analyse en concrete verbeterpunten</li>
            <li>Wekelijkse optimalisatie op ROAS, CPL en kwaliteitsscore</li>
            <li>Volledige conversietracking via GA4 en Google Tag Manager</li>
            <li>Maandelijkse rapportage met conclusies en strategische aanbevelingen</li>
          </ul>
        </article>
      </div>
    </section>

    <!-- FAQ -->
    <section class="sea-faq" data-bg-color="#F7F9FC">
      <div class="sea-container sea-faq-grid">
        <div class="sea-faq-left">
          <span class="sea-label">Veelgestelde vragen</span>
          <h2>Alles over SEA uitbesteden</h2>
          <p>Staat jouw vraag er niet bij? Neem gerust contact op voor een vrijblijvend gesprek.</p>
          <a href="#contact" class="sea-inline-cta" data-overlay-open>Stel je vraag →</a>
        </div>
        <div class="sea-faq-right">
          {faq.map((item) => (
            <details class="sea-faq-item">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Outcomes -->
    <section class="sea-outcomes" data-bg-color="#0A0A0A">
      <div class="sea-container">
        <h2>Resultaten die je mag verwachten</h2>
        <div class="sea-outcome-tags">
          <span>Lagere kosten per acquisitie</span>
          <span>Hogere leadkwaliteit</span>
          <span>Realtime inzicht via dashboard</span>
          <span>Snelle schaalbaarheid</span>
          <span>Minder budgetverspilling</span>
          <span>Voorspelbare leadinstroom</span>
          <span>Volledig accounteigenaarschap</span>
          <span>Geïntegreerde kanaalstrategie</span>
        </div>
      </div>
    </section>

    <section class="sea-related-reads" data-bg-color="#F7F9FC">
      <div class="sea-container">
        <span class="sea-related-kicker">Gerelateerd</span>
        <div class="sea-related-grid">
          <a href="/vergelijk/seo-vs-sea" class="sea-related-card">
            <strong>SEO vs. SEA</strong>
            <span>Wanneer kies je organisch, wanneer betaald?</span>
          </a>
          <a href="/tracking-audit" class="sea-related-card">
            <strong>Gratis Tracking-audit</strong>
            <span>Ontdek of je Google Ads conversies correct meet.</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section" id="contact" data-bg-color="#0A0A0A">
      <div class="cta-content">
        <h2>Klaar voor winstgevende<br/>Google Ads campagnes?</h2>
        <p>We vertalen jouw doelstellingen naar een concreet campagneplan met duidelijke KPI's, scope en verwachte resultaten.</p>
        <a href="#" class="cta-button" data-overlay-open>Plan kennismaking</a>
      </div>
    </section>

    <Footer />
    <ContactOverlay />
  </main>
</BaseLayout>

<style is:global>
  .sea-page { background: var(--white); }

  /* ── Shared ── */
  .sea-container {
    max-width: 1240px;
    margin: 0 auto;
  }

  .sea-label {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 0.75rem;
  }

  .sea-section-head { margin-bottom: 3rem; }
  .sea-section-head h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.9rem, 3.6vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.022em;
  }

  .sea-section-head.centered { text-align: center; }
  .sea-section-head.centered h2,
  .sea-section-head.centered p { margin-left: auto; margin-right: auto; }
  .sea-section-head.centered p { max-width: 560px; }
  .sea-section-head p {
    color: rgba(10,10,10,0.62);
    line-height: 1.8;
    margin-top: 0.75rem;
    max-width: 600px;
  }

  .sea-inline-cta {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--black);
    border-bottom: 1.5px solid var(--black);
    padding-bottom: 2px;
    transition: opacity 0.2s ease;
  }

  .sea-inline-cta:hover { opacity: 0.6; }

  /* ── Hero ── */
  .sea-hero {
    min-height: 88vh;
    position: relative;
    background: var(--black);
    color: var(--white);
    padding: 10rem 4rem 5.5rem;
    overflow: hidden;
  }

  .sea-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 214, 232, 0.18), transparent 42%),
      radial-gradient(circle at 82% 24%, rgba(200, 231, 245, 0.14), transparent 38%);
  }

  .sea-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 2rem;
    align-items: end;
  }

  .sea-back-link {
    display: inline-flex;
    margin-bottom: 1.8rem;
    color: var(--white);
    text-decoration: none;
    opacity: 0.6;
    font-size: 0.9rem;
    transition: opacity 0.25s ease;
  }
  .sea-back-link:hover { opacity: 1; }

  .sea-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.48;
    margin-bottom: 1rem;
  }

  .sea-hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.6rem, 6vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 1.4rem;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
  }

  .sea-icon { color: var(--pastel-pink); font-size: 0.68em; }

  .sea-intro-p {
    max-width: 700px;
    font-size: clamp(1.04rem, 2.3vw, 1.3rem);
    opacity: 0.88;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .sea-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2rem; }

  .sea-btn-primary,
  .sea-btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    padding: 0.9rem 1.45rem;
    transition: transform 0.25s ease;
  }
  .sea-btn-primary { color: var(--black); background: var(--white); }
  .sea-btn-secondary {
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.28);
    background: rgba(255,255,255,0.06);
  }
  .sea-btn-primary:hover,
  .sea-btn-secondary:hover { transform: translateY(-2px); }

  .sea-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
    max-width: 720px;
  }

  .sea-metric {
    border-top: 1px solid rgba(255,255,255,0.2);
    padding: 0.75rem 0;
  }
  .sea-metric strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 1.25rem;
    margin-bottom: 0.2rem;
  }
  .sea-metric span {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .sea-hero-panel {
    border-left: 1px solid rgba(255,255,255,0.25);
    padding: 0.5rem 0 0.5rem 1.5rem;
  }
  .sea-hero-panel > span {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.58;
    margin-bottom: 0.75rem;
  }
  .sea-hero-panel ul { list-style: none; display: grid; gap: 0.65rem; }
  .sea-hero-panel li {
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
    opacity: 0.92;
  }
