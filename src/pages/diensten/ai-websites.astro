    metrics={[
      { value: "Vanaf €795", label: "Complete website" },
      { value: "1-2 weken", label: "Naar live" },
      { value: "Eigen CMS", label: "Zelf beheren" },
    ]}
    painPoints={[
      "Een professionele website voelt te duur als startende ondernemer",
      "Weken of maanden wachten op een bureau terwijl je nú online wilt",
