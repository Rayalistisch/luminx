---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServicePage from "../../components/ServicePage.astro";
import { cities, services } from "../../data/regional";
import type { City, ServiceDef } from "../../data/regional";

export function getStaticPaths() {
  const paths = [];
  for (const city of cities) {
    for (const [serviceKey, service] of Object.entries(services)) {
      paths.push({
        params: { slug: `${serviceKey}-${city.slug}` },
        props: { city, service, serviceKey },
      });
    }
  }
  return paths;
}

interface Props {
  city: City;
  service: ServiceDef;
  serviceKey: string;
}

const { city, service, serviceKey } = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://luminx.nl";

const parentServiceMap: Record<string, { label: string; href: string }> = {
  seo: { label: "Online Marketing", href: "/diensten/online-marketing" },
  sea: { label: "Online Marketing", href: "/diensten/online-marketing" },
  emailmarketing: { label: "Online Marketing", href: "/diensten/online-marketing" },
  "social-advertising": { label: "Online Marketing", href: "/diensten/online-marketing" },
  "online-marketing": { label: "Online Marketing", href: "/diensten/online-marketing" },
};

const otherCities = cities.filter((c) => c.slug !== city.slug);

const localBusinessSchema = {
  "@type": "ProfessionalService",
  name: "LuminX",
  url: siteOrigin,
  email: "hello@luminx.nl",
  areaServed: {
    "@type": "City",
    name: city.name,
    containedInPlace: {
      "@type": "AdministrativeArea",
      name: "Twente",
    },
  },
  serviceType: service.label,
};
---

<BaseLayout
  title={service.metaTitle(city.name)}
  description={service.metaDesc(city.name)}
  structuredData={localBusinessSchema}
>
  <ServicePage
    title={`${service.label} in ${city.name}`}
    icon={service.icon}
    intro={service.intro(city.name, city.context)}
    metrics={service.metrics}
    painPoints={service.painPoints}
    highlights={service.highlights}
    process={service.process}
    outcomes={service.outcomes}
    parentService={parentServiceMap[serviceKey]}
  >
    {serviceKey === "online-marketing" && (
      <div slot="body" class="regional-body">
        <div class="regional-col">
          <h2>De markt in {city.name}</h2>
          <p>{city.marketNote}</p>
          <p>LuminX is het <a href="/diensten/online-marketing">online marketing bureau</a> dat voor bedrijven in {city.name} meetbare groei realiseert via de kanalen die echt bijdragen.</p>
        </div>

        <div class="regional-col">
          <h2>Kanalen die we inzetten</h2>
          <ul>
            <li><a href="/diensten/seo">SEO</a> — structurele zichtbaarheid zonder doorlopende advertentiekosten</li>
            <li><a href="/diensten/sea">Google Ads</a> — direct bovenaan bij actieve zoekopdrachten</li>
            <li><a href="/diensten/social-advertising">Social Advertising</a> — bereik op Meta en LinkedIn</li>
            <li><a href="/diensten/emailmarketing">E-mailmarketing</a> — leads nurturen en klanten activeren</li>
          </ul>
          <p class="regional-other">
            Ook actief in:
            {otherCities.map((c, i) => (
              <>
                <a href={`/regio/online-marketing-${c.slug}`}>{c.name}</a>{i < otherCities.length - 1 ? ", " : ""}
              </>
            ))}
          </p>
        </div>
      </div>
    )}
  </ServicePage>
</BaseLayout>

<style>
  .regional-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .regional-other {
    font-size: 0.85rem !important;
    opacity: 0.6;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .regional-body {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
