---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServicePage from "../../components/ServicePage.astro";
import { cities, services } from "../../data/regional";
import type { City, ServiceDef } from "../../data/regional";

export function getStaticPaths() {
  const paths = [];
  for (const city of cities) {
    for (const [serviceKey, service] of Object.entries(services)) {
      paths.push({
        params: { slug: `${serviceKey}-${city.slug}` },
        props: { city, service, serviceKey },
      });
    }
  }
  return paths;
}

interface Props {
  city: City;
  service: ServiceDef;
  serviceKey: string;
}

const { city, service, serviceKey } = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://luminx.nl";

const parentServiceMap: Record<string, { label: string; href: string }> = {
  seo: { label: "Online Marketing", href: "/diensten/online-marketing" },
  sea: { label: "Online Marketing", href: "/diensten/online-marketing" },
  emailmarketing: { label: "Online Marketing", href: "/diensten/online-marketing" },
  "social-advertising": { label: "Online Marketing", href: "/diensten/online-marketing" },
  "online-marketing": { label: "Online Marketing", href: "/diensten/online-marketing" },
};

const otherCities = cities.filter((c) => c.slug !== city.slug);

const localBusinessSchema = {
  "@type": "ProfessionalService",
  name: "LuminX",
  url: siteOrigin,
  email: "hello@luminx.nl",
  areaServed: {
    "@type": "City",
    name: city.name,
    containedInPlace: {
      "@type": "AdministrativeArea",
      name: "Twente",
    },
  },
  serviceType: service.label,
};
---

<BaseLayout
  title={service.metaTitle(city.name)}
  description={service.metaDesc(city.name)}
  structuredData={localBusinessSchema}
>
  <ServicePage
    title={`${service.label} in ${city.name}`}
    icon={service.icon}
    intro={service.intro(city.name, city.context)}
    metrics={service.metrics}
    painPoints={service.painPoints}
    highlights={service.highlights}
    process={service.process}
    outcomes={service.outcomes}
    parentService={parentServiceMap[serviceKey]}
  >
    {serviceKey === "online-marketing" && (
      <div slot="body">
        <h2>Online marketing in {city.name}: wat werkt er echt?</h2>
        <p>
          Bedrijven in {city.name} die online willen groeien, hebben meer nodig dan losse campagnes. Een samenhangende strategie — waarbij SEO, Google Ads en social advertising elkaar versterken — is wat het verschil maakt tussen zichtbaarheid en daadwerkelijke leadgeneratie.
        </p>
        <p>
          LuminX is het <a href="/diensten/online-marketing">online marketing bureau</a> dat voor bedrijven in {city.name} en heel Twente meetbare groei realiseert. We combineren de juiste kanalen op basis van jouw doelgroep, budget en groeifase.
        </p>

        <h2>De kanalen die we voor {city.name} inzetten</h2>
        <p>Afhankelijk van jouw markt en ambitie zetten we een of meerdere kanalen in:</p>
        <ul>
          <li><a href="/diensten/seo">SEO in {city.name}</a> — structurele zichtbaarheid in Google zonder doorlopende advertentiekosten. Ideaal voor bedrijven die langdurige autoriteit willen opbouwen.</li>
          <li><a href="/diensten/sea">Google Ads (SEA) in {city.name}</a> — directe zichtbaarheid op het moment dat iemand zoekt naar jouw product of dienst. Meetbaar rendement per klik.</li>
          <li><a href="/diensten/social-advertising">Social Advertising</a> — bereik via Meta en LinkedIn op doelgroepen die jouw bedrijf nog niet kennen. Sterk voor merkbekendheid en retargeting.</li>
          <li><a href="/diensten/emailmarketing">E-mailmarketing</a> — geautomatiseerde flows die leads nurturen en bestaande klanten activeren op het juiste moment.</li>
        </ul>

        <h2>Waarom lokale focus belangrijk is</h2>
        <p>
          {city.context} Voor bedrijven in {city.name} betekent dat: er is een actieve lokale markt, maar ook concurrentie die online al zichtbaar is. Door nu te investeren in een doordachte online marketingaanpak, bouw je een positie op die moeilijk in te halen is.
        </p>
        <p>
          LuminX werkt ook voor bedrijven in andere steden in Twente:
          {otherCities.map((c, i) => (
            <>
              <a href={`/regio/online-marketing-${c.slug}`}>Online Marketing {c.name}</a>{i < otherCities.length - 1 ? ", " : "."}
            </>
          ))}
        </p>
      </div>
    )}
  </ServicePage>
</BaseLayout>
