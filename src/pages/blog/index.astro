---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ContactOverlay from '../../components/ContactOverlay.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Blog | LuminX — Online Marketing & Digitale Groei"
  description="Praktische inzichten over online marketing, SEO, SEA en digitale strategie voor bedrijven in Twente."
>
  <div class="cursor"></div>
  <div class="cursor-follower"></div>
  <Nav basePath="/" />

  <main class="blog-page">
    <section class="blog-hero" data-bg-color="#0A0A0A">
      <div class="blog-hero-overlay" aria-hidden="true"></div>
      <div class="blog-hero-inner">
        <a href="/" class="blog-back-link">Terug naar homepage</a>
        <span class="blog-kicker">Kennisbank</span>
        <h1>Blog</h1>
        <p>Praktische inzichten over online marketing, SEO en digitale groei. Geschreven vanuit de praktijk.</p>
      </div>
    </section>

    <section class="blog-list" data-bg-color="#FEFEFE">
      <div class="blog-list-inner">
        {posts.length === 0 && (
          <p class="blog-empty">Binnenkort verschijnen hier de eerste artikelen.</p>
        )}
        <ul class="blog-grid">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="blog-card">
                {post.data.image && (
                  <div class="blog-card-image">
                    <img src={post.data.image} alt={post.data.title} loading="lazy" decoding="async" />
                  </div>
                )}
                <div class="blog-card-body">
                  {post.data.category && (
                    <span class="blog-card-category">{post.data.category}</span>
                  )}
                  <h2 class="blog-card-title">{post.data.title}</h2>
                  <p class="blog-card-desc">{post.data.description}</p>
                  <div class="blog-card-footer">
                    <span class="blog-card-date">{formatDate(post.data.pubDate)}</span>
                    <span class="blog-card-read">Lees artikel →</span>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <Footer />
    <ContactOverlay />
  </main>
</BaseLayout>

<style>
  .blog-page { background: var(--white); }

  .blog-hero {
    min-height: 52vh;
    position: relative;
    background: var(--black);
    color: var(--white);
    padding: 10rem 4rem 5rem;
    overflow: hidden;
  }

  .blog-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 214, 232, 0.15), transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(200, 231, 245, 0.12), transparent 38%);
  }

  .blog-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
  }

  .blog-back-link {
    display: inline-flex;
    margin-bottom: 1.8rem;
    color: var(--white);
    text-decoration: none;
    opacity: 0.6;
    font-size: 0.9rem;
    transition: opacity 0.25s ease;
  }
  .blog-back-link:hover { opacity: 1; }

  .blog-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.48;
    margin-bottom: 1rem;
  }

  .blog-hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 1.2rem;
  }

  .blog-hero p {
    max-width: 560px;
    font-size: clamp(1rem, 2vw, 1.2rem);
    opacity: 0.8;
    line-height: 1.7;
  }

  /* List */
  .blog-list {
    padding: 5rem 4rem 7rem;
  }

  .blog-list-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .blog-empty {
    color: rgba(10,10,10,0.5);
    font-size: 1rem;
  }

  .blog-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(10,10,10,0.1);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: var(--black);
    background: var(--white);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    height: 100%;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(10,10,10,0.1);
    border-color: rgba(10,10,10,0.22);
  }

  .blog-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f0f2f5;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.04);
  }

  .blog-card-body {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
  }

  .blog-card-category {
    font-family: 'Syne', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(10,10,10,0.45);
  }

  .blog-card-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .blog-card-desc {
    font-size: 0.88rem;
    color: rgba(10,10,10,0.65);
    line-height: 1.7;
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(10,10,10,0.08);
  }

  .blog-card-date {
    font-size: 0.78rem;
    color: rgba(10,10,10,0.42);
  }

  .blog-card-read {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--black);
  }

  @media (max-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .blog-hero,
    .blog-list {
      padding-left: 2rem;
      padding-right: 2rem;
    }
    .blog-hero { padding-top: 8rem; }
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
