---
import GlowMenu from "./ui/glow-menu";

interface Props {
  basePath?: string;
}

const { basePath = "" } = Astro.props;

const toSection = (id: string) => `${basePath}#${id}`;

const navItems = [
  {
    icon: "Layers",
    label: "Diensten",
    href: toSection("diensten"),
    gradient: "radial-gradient(circle, rgba(200,231,245,0.15) 0%, rgba(200,231,245,0.06) 50%, rgba(200,231,245,0) 100%)",
    iconColor: "text-[#C8E7F5]",
    dropdown: [
      {
        category: "Online Marketing",
        items: [
          { label: "SEO", href: "/diensten/seo" },
          { label: "SEA", href: "/diensten/sea" },
          { label: "Social Advertising", href: "/diensten/social-advertising" },
          { label: "E-mailmarketing", href: "/diensten/emailmarketing" },
          { label: "GEO – AI-zichtbaarheid", href: "/diensten/geo" },
        ],
      },
      {
        category: "Technologie",
        items: [
          { label: "Websites", href: "/diensten/websites" },
          { label: "Webshops", href: "/diensten/webshops" },
          { label: "Procesautomation", href: "/diensten/procesautomation" },
        ],
      },
      {
        category: "Strategie & Data",
        items: [
          { label: "Strategie", href: "/diensten/strategy" },
          { label: "Google Tag Manager", href: "/diensten/google-tag-manager" },
          { label: "GA4 Implementatie", href: "/diensten/ga4-implementatie" },
          { label: "Consent Mode v2", href: "/diensten/consent-mode-v2" },
        ],
      },
    ],
  },
  {
    icon: "LayoutGrid",
    label: "Werk",
    href: toSection("werk"),
    gradient: "radial-gradient(circle, rgba(255,214,232,0.15) 0%, rgba(255,214,232,0.06) 50%, rgba(255,214,232,0) 100%)",
    iconColor: "text-[#FFD6E8]",
  },
  {
    icon: "User",
    label: "Over",
    href: toSection("over"),
    gradient: "radial-gradient(circle, rgba(232,213,245,0.15) 0%, rgba(232,213,245,0.06) 50%, rgba(232,213,245,0) 100%)",
    iconColor: "text-[#E8D5F5]",
  },
];
---

<nav class="site-nav">
  <a href={basePath || "/"} class="logo">
    {"LUMINX".split("").map((letter, i) => (
      <span class="logo-letter" style={`transition-delay: ${i * 0.04}s`}>{letter}</span>
    ))}
  </a>

  <div class="nav-glow-wrapper">
    <GlowMenu client:load items={navItems} />
  </div>

  <div class="nav-mobile-pill-actions">
    <a href="#" class="nav-mobile-cta" data-overlay-open aria-label="Contact">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="7" y1="17" x2="17" y2="7"/>
        <polyline points="7 7 17 7 17 17"/>
      </svg>
    </a>

    <button class="nav-burger" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
  </div>

  <a href="#" class="nav-cta" data-overlay-open>
    <span class="nav-cta-label">Maak kennis</span>
    <span class="nav-cta-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="7" y1="17" x2="17" y2="7"/>
        <polyline points="7 7 17 7 17 17"/>
      </svg>
    </span>
  </a>

  <div class="mobile-menu">
    <ul class="mobile-menu-links">
      <li><a href={toSection("werk")}>Werk</a></li>
      <li>
        <button class="mobile-diensten-toggle" type="button">Diensten <span class="mobile-chevron">+</span></button>
        <ul class="mobile-diensten-sub">
          <li class="mobile-sub-category">Online Marketing</li>
          <li><a href="/diensten/seo">SEO</a></li>
          <li><a href="/diensten/sea">SEA – Google Ads</a></li>
          <li><a href="/diensten/social-advertising">Social Advertising</a></li>
          <li><a href="/diensten/emailmarketing">E-mailmarketing</a></li>
          <li><a href="/diensten/geo">GEO – AI-zichtbaarheid</a></li>
          <li class="mobile-sub-category">Technologie</li>
          <li><a href="/diensten/websites">Websites</a></li>
          <li><a href="/diensten/webshops">Webshops</a></li>
          <li><a href="/diensten/procesautomation">Procesautomation</a></li>
          <li class="mobile-sub-category">Strategie & Data</li>
          <li><a href="/diensten/strategy">Strategie</a></li>
          <li><a href="/diensten/google-tag-manager">Google Tag Manager</a></li>
          <li><a href="/diensten/ga4-implementatie">GA4 Implementatie</a></li>
        </ul>
      </li>
      <li><a href={toSection("over")}>Over</a></li>
      <li><a href={toSection("contact")}>Contact</a></li>
    </ul>
    <a href="#" class="mobile-menu-cta" data-overlay-open>Start Project</a>
  </div>
</nav>
