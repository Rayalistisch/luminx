---
interface Props {
  basePath?: string;
}

const { basePath = "" } = Astro.props;

const toSection = (id: string) => `${basePath}#${id}`;
---

<nav>
  <div class="nav-pill">
    <a href={basePath || "/"} class="nav-logo-mark" aria-label="LuminX homepage">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4.5"/>
        <path d="M3 8.5C5.5 6 9.5 5 12 5s7 1.5 9 3.5C18.5 11 14.5 13 12 13S5.5 11 3 8.5z" opacity="0.55"/>
      </svg>
    </a>

    <ul class="nav-links">
      <li><a href={toSection("werk")}>Werk</a></li>
      <li><a href={toSection("diensten")}>Diensten</a></li>
      <li><a href={toSection("over")}>Over</a></li>
      <li><a href={toSection("contact")}>Contact</a></li>
    </ul>

    <a href="#" class="nav-cta" data-overlay-open>Plan kennismaking</a>

    <button class="nav-burger" aria-label="Menu">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-menu">
    <ul class="mobile-menu-links">
      <li><a href={toSection("werk")}>Werk</a></li>
      <li><a href={toSection("diensten")}>Diensten</a></li>
      <li><a href={toSection("over")}>Over</a></li>
      <li><a href={toSection("contact")}>Contact</a></li>
    </ul>
    <a href="#" class="mobile-menu-cta" data-overlay-open>Start Project</a>
  </div>
</nav>
