<script is:inline>
  (function () {
    var calendarUrl = "https://calendar.google.com/calendar/appointments/schedules/AcZssZ0KnPaRiH37bvNSB0ta7HrOtyHk8wT8EUaAMULRWJcV8kywKhl-TEVeRu1YsOLCFd3vzfBt6dve?gv=true";
    var tries = 0;

    function closeOverlay() {
      var overlay = document.getElementById("contact-overlay");
      if (!overlay) return;
      overlay.classList.remove("is-open");
      document.body.style.overflow = "";
    }

    // Watch for Google's popup iframe and boost its z-index above the overlay
    var observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        m.addedNodes.forEach(function (node) {
          if (node.nodeType !== 1) return;
          // Google scheduling popup: iframe or container with iframe
          var iframe = node.tagName === "IFRAME" ? node : node.querySelector && node.querySelector("iframe");
          if (iframe && iframe.src && iframe.src.indexOf("calendar.google.com") !== -1) {
            var target = iframe.parentElement && iframe.parentElement !== document.body ? iframe.parentElement : iframe;
            target.style.setProperty("z-index", "99999999", "important");
          }
        });
      });
    });
    observer.observe(document.body, { childList: true, subtree: true });

    function initSchedulingButton() {
      var slot = document.getElementById("overlay-calendar-button-slot");
      if (!slot || slot.dataset.initialized === "true") return;
      if (!window.calendar || !window.calendar.schedulingButton) return;

      window.calendar.schedulingButton.load({
        url: calendarUrl,
        color: "#A79B8E",
        label: "Plan een videocall",
        target: slot,
      });

      slot.dataset.initialized = "true";
      slot.classList.add("is-ready");

      // Close overlay when the Google button is clicked
      slot.addEventListener("click", function () {
        closeOverlay();
      }, true);
    }

    function initWithRetry() {
      var timer = window.setInterval(function () {
        tries += 1;
        initSchedulingButton();
        var slot = document.getElementById("overlay-calendar-button-slot");
        if ((slot && slot.dataset.initialized === "true") || tries >= 40) {
          window.clearInterval(timer);
        }
      }, 100);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initWithRetry);
    } else {
      initWithRetry();
    }
  })();
</script>

