---
const allDiensten = [
  {
    title: "SEO",
    description: "Hogere organische posities via technische optimalisatie, content en linkbuilding die duurzaam verkeer opleveren.",
    href: "/diensten/seo",
    tag: "Online Marketing",
  },
  {
    title: "SEA",
    description: "Campagnes die op het juiste moment zichtbaar zijn, gericht op conversie en een sterke ROAS.",
    href: "/diensten/sea",
    tag: "Online Marketing",
  },
  {
    title: "Social Advertising",
    description: "Meta, LinkedIn en TikTok campagnes die je doelgroep bereiken en merkbekendheid omzetten in leads.",
    href: "/diensten/social-advertising",
    tag: "Online Marketing",
  },
  {
    title: "E-mailmarketing",
    description: "Geautomatiseerde flows en nieuwsbrieven die leads nurturen en klanten activeren op het juiste moment.",
    href: "/diensten/emailmarketing",
    tag: "Online Marketing",
  },
  {
    title: "GEO",
    description: "Zichtbaar in ChatGPT, Gemini en Perplexity. Optimaliseer je content zodat AI-zoekmachines jou als autoriteit citeren.",
    href: "/diensten/geo",
    tag: "Online Marketing",
  },
  {
    title: "Websites",
    description: "Custom sites, Framer of WordPress — altijd met premium uitstraling, hoge performance en conversiefocus.",
    href: "/diensten/websites",
    tag: "Technologie",
  },
  {
    title: "Webshops",
    description: "Shopify en WooCommerce shops die verkopen. Geoptimaliseerde checkout, productfeeds en e-commerce tracking.",
    href: "/diensten/webshops",
    tag: "Technologie",
  },
  {
    title: "Procesautomation",
    description: "Automatiseer repetitieve processen en maak je operatie sneller, consistenter en schaalbaar zonder extra mensen.",
    href: "/diensten/procesautomation",
    tag: "Technologie",
  },
  {
    title: "Strategie",
    description: "Van positionering tot roadmap: concrete keuzes die je marketing en groei richting geven op basis van data.",
    href: "/diensten/strategy",
    tag: "Strategie",
  },
];
---

<section class="diensten-section" id="diensten">
  <div class="diensten-inner">

    <div class="diensten-head">
      <div class="diensten-head-left">
        <span class="diensten-kicker">Onze diensten</span>
        <h2>Wat we<br/>voor je doen</h2>
      </div>
      <p class="diensten-head-desc">Van zoekmachineoptimalisatie tot procesautomatisering: een volledig pakket dat je zichtbaarheid, bereik en omzet vergroot.</p>
    </div>

    <ul class="diensten-list" role="list">
      {allDiensten.map((item, i) => (
        <li class="diensten-row">
          <a href={item.href} class="diensten-row-link">
            <span class="diensten-row-num">0{i + 1}</span>
            <span class="diensten-row-body">
              <span class="diensten-row-title-wrap">
                <span class="diensten-row-title">{item.title}</span>
                <span class="diensten-row-dot" aria-hidden="true"></span>
              </span>
              <span class="diensten-row-desc">{item.description}</span>
            </span>
            <span class="diensten-row-arrow" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .diensten-section {
    padding: 7rem 4rem;
    background: var(--white);
    color: var(--black);
  }

  .diensten-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  /* ── Header ── */
  .diensten-head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }

  .diensten-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.42;
    margin-bottom: 1.2rem;
  }

  .diensten-head h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--black);
  }

  .diensten-head-desc {
    font-size: 0.97rem;
    line-height: 1.78;
    color: rgba(10,10,10,0.5);
    padding-bottom: 0.4rem;
  }

  /* ── List ── */
  .diensten-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Row ── */
  .diensten-row {
    border-top: 1px solid rgba(10,10,10,0.1);
  }

  .diensten-list li:last-child {
    border-bottom: 1px solid rgba(10,10,10,0.1);
  }

  .diensten-row-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: start;
    gap: 0 2rem;
    padding: 2rem 0;
    text-decoration: none;
    color: var(--black);
    overflow: hidden;
  }

  .diensten-row-body {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* num */
  .diensten-row-num {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    opacity: 0.28;
    transition: opacity 0.25s ease;
    padding-top: 0.35rem;
  }

  .diensten-row-link:hover .diensten-row-num {
    opacity: 0.5;
  }

  /* title wrap */
  .diensten-row-title-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    transform-origin: left center;
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .diensten-row-link:hover .diensten-row-title-wrap {
    transform: scale(1.35);
  }

  /* title */
  .diensten-row-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  /* square dot */
  .diensten-row-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: #A07828;
    border-radius: 2px;
    opacity: 0;
    transform: scale(0) rotate(45deg);
    transition: opacity 0.5s ease 0.25s, transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.25s;
    flex-shrink: 0;
  }

  .diensten-row-link:hover .diensten-row-dot {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  /* tag */
  .diensten-row-tag {
    display: none;
  }

  /* description */
  .diensten-row-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(10,10,10,0.5);
    max-width: 52ch;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                opacity 0.25s ease,
                margin-top 0.3s ease;
    margin-top: 0;
  }

  .diensten-row-link:hover .diensten-row-desc {
    max-height: 6rem;
    opacity: 1;
    margin-top: 0.6rem;
  }

  /* arrow */
  .diensten-row-arrow {
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 0.4s ease 0.1s, transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s;
  }

  .diensten-row-link:hover .diensten-row-arrow {
    opacity: 0.7;
    transform: translateX(0);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .diensten-head {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .diensten-section {
      padding: 5rem 2rem;
    }

    .diensten-row-link {
      grid-template-columns: 2rem 1fr auto;
      align-items: center;
    }

    .diensten-row-tag,
    .diensten-row-desc {
      display: none;
    }

    .diensten-row-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 1;
      transform: translateX(0);
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(10,10,10,0.15);
      flex-shrink: 0;
      transition: none;
    }

    .diensten-row-title {
      font-size: clamp(1.1rem, 5vw, 1.5rem);
      word-break: break-word;
    }

    .diensten-row-link:hover .diensten-row-title-wrap {
      transform: none;
    }

    .diensten-row-link:hover .diensten-row-dot {
      display: none;
    }
  }
</style>
