---
const projects = [
  {
    title: "GSM Team",
    result: "40% snellere laadtijd, 0 dagen downtime",
    tag: "Migratie",
    description: "WordPress → Shopify migratie met volledig behoud van SEO-waarde.",
    image: "/images/website-gsmteam.png",
    href: "/cases/migraties",
  },
  {
    title: "ReservaX / ActifAid",
    result: "5+ uur per week teruggewonnen",
    tag: "Websites · Procesautomation",
    description: "Custom afsprakensysteem dat handmatige planning volledig vervangt.",
    image: "/images/reservaxactifaid.png",
    href: "/cases/custom-applicaties",
  },
  {
    title: "Ascendio",
    result: "3× meer organisch verkeer",
    tag: "SEO · AI Automation",
    description: "AI-gedreven content clusters die autoriteit en verkeer laten samenkomen.",
    image: "/images/ascendio seo automation.jpg",
    href: "/cases/digital-marketing",
  },
];
---

<section class="projects-section" id="werk" data-bg-color="#000000">
  <div class="section-header projects-head">
    <span class="section-kicker kicker">Geselecteerd werk</span>
    <h2>Bewijs, geen beloftes.</h2>
  </div>

  <div class="projects-list">
    {projects.map((p, i) => (
      <a class="project-card" href={p.href} data-index={i}>
        <div class="project-media">
          <img src={p.image} alt={p.title} loading="lazy" decoding="async" />
        </div>
        <div class="project-info">
          <span class="project-tag">{p.tag}</span>
          <h3 class="project-title">{p.title}</h3>
          <p class="project-desc">{p.description}</p>
          <span class="project-result">{p.result}</span>
        </div>
        <span class="project-arrow" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>

<script>
  function init() {
    const cards = document.querySelectorAll<HTMLElement>(".project-card");
    if (!cards.length) return;

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("is-visible");
        });
      },
      { threshold: 0.15 }
    );
    cards.forEach((c) => io.observe(c));

    if (!window.matchMedia("(pointer: fine)").matches) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    cards.forEach((card) => {
      const media = card.querySelector<HTMLElement>(".project-media");
      if (!media) return;

      let targetX = 0;
      let targetY = 0;
      let curX = 0;
      let curY = 0;
      let raf = 0;

      const tick = () => {
        curX += (targetX - curX) * 0.12;
        curY += (targetY - curY) * 0.12;
        media.style.transform = `rotateX(${curY}deg) rotateY(${curX}deg)`;
        raf = requestAnimationFrame(tick);
      };

      card.addEventListener("mouseenter", () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(tick);
      });

      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const px = (e.clientX - rect.left) / rect.width - 0.5;
        const py = (e.clientY - rect.top) / rect.height - 0.5;
        targetX = px * 8;
        targetY = -py * 8;
      });

      card.addEventListener("mouseleave", () => {
        targetX = 0;
        targetY = 0;
        setTimeout(() => cancelAnimationFrame(raf), 400);
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  .projects-section {
    /* Positioned + isolated so this section reliably paints on top of the
       hero's fixed portrait image (position:static sections lose to any
       positioned/isolated ancestor regardless of DOM order — that's what
       let the image bleed through here before). */
    position: relative;
    isolation: isolate;
    background: var(--void);
    padding: 7rem 0;
  }

  .projects-head {
    max-width: 1200px;
    margin: 0 auto 4rem;
    padding: 0 clamp(20px, 5vw, 56px);
  }

  .projects-head h2 {
    margin: 0;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    color: var(--ink);
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
    text-decoration: none;
    color: var(--ink);
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-media {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    background: var(--panel);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transform-style: preserve-3d;
    perspective: 1000px;
    will-change: transform;
  }

  .project-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .project-card:hover .project-media img {
    transform: scale(1.04);
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 640px;
  }

  .project-tag {
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--signal-bright);
  }

  .project-title {
    margin: 0;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    letter-spacing: -0.02em;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .project-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
  }

  .project-result {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  .project-arrow {
    display: none;
  }

  @media (min-width: 900px) {
    .project-card {
      grid-template-columns: 1.4fr 1fr;
      align-items: center;
    }

    .project-card:nth-child(even) {
      direction: rtl;
    }
    .project-card:nth-child(even) > * {
      direction: ltr;
    }
  }

  @media (max-width: 640px) {
    .projects-section { padding: 5rem 0; }
    .projects-list { gap: 4rem; }
  }
</style>
