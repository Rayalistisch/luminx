---
import { CaseFeatures } from "./ui/case-features";
---

<section class="image-grid-section" id="werk">
  <div class="section-header">
    <span class="section-kicker">Cases</span>
    <h2>Geselecteerd werk</h2>
    <p>Projecten waar strategie en uitvoering samenkomen, <br>altijd met meetbare resultaten.</p>
  </div>

  <div class="cases-wrapper">
    <CaseFeatures client:load />
  </div>

  <div class="cases-footer">
    <a href="/#werk" class="cases-all-link">Bekijk alle cases →</a>
  </div>
</section>

<style>
  .cases-wrapper {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
