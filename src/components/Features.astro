---
import { Image } from "astro:assets";
import founderImage from "../assets/images/luminx-founder.png";

const services = [
  {
    num: "01",
    title: "Procesautomation",
    description: "Automatiseer repetitieve processen en maak je operatie sneller, consistenter en schaalbaar.",
    href: "/diensten/procesautomation",
  },
  {
    num: "02",
    title: "Web Development",
    description: "Websites met premium uitstraling, hoge performance en een duidelijke conversiefocus.",
    href: "/diensten/web-development",
  },
  {
    num: "03",
    title: "Strategy",
    description: "Van positionering tot roadmap: concrete keuzes die je marketing en groei richting geven.",
    href: "/diensten/strategy",
  },
  {
    num: "04",
    title: "Online Marketing",
    description: "Campagnes en funnels die voorspelbaar leads genereren en continu geoptimaliseerd worden op data.",
    href: "/diensten/online-marketing",
  },
];
---

<section class="features-section" id="diensten" data-bg-color="#FEFEFE">
  <div class="features-inner">
    <div class="features-head">
      <span class="features-kicker">Onze Diensten</span>
      <h2>Wat we voor<br/>jou doen</h2>
      <p>Van strategie tot uitvoering: een volledig pakket waarmee je online zichtbaarheid, bereik en omzet groeit.</p>
    </div>

    <div class="features-list">
      {services.map((service) => (
        <a class="feature-row" href={service.href}>
          <span class="feature-num">{service.num}</span>
          <div class="feature-body">
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
          <span class="feature-arrow" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="about-section" id="over" data-bg-color="#FEFEFE">
  <div class="about-content">
    <span class="about-kicker">Over LUMINX</span>
    <h2>Creatief, technisch en altijd gericht op schaalbare groei.</h2>
    <p>
      LUMINX helpt merken groeien met strategie, automatisering en digitale producten die echt werken.
      Geen losse acties, maar een doordachte aanpak waarin design, data en operatie samenkomen.
    </p>
    <p>
      We bouwen oplossingen die je team tijd geven, meer grip op resultaat bieden en klaar zijn voor de
      volgende fase van je bedrijf.
    </p>
    <a href="#" class="about-cta" data-overlay-open>Plan een kennismaking</a>
  </div>

  <div class="about-image-wrap">
    <Image
      class="about-image"
      src={founderImage}
      alt="Portret van de oprichter van LUMINX"
      widths={[420, 640, 920]}
      sizes="(max-width: 1024px) 100vw, 48vw"
      loading="lazy"
    />
  </div>
</section>

<style>
  /* ── Diensten ── */
  .features-section {
    padding: 6rem 4rem;
    background: var(--white);
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 6rem;
    align-items: start;
  }

  .features-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.42;
    margin-bottom: 1.2rem;
  }

  .features-head h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-bottom: 1.2rem;
  }

  .features-head p {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(10,10,10,0.55);
    max-width: 30ch;
  }

  /* ── Service rows ── */
  .features-list {
    display: flex;
    flex-direction: column;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 3rem 1fr 2rem;
    gap: 1.5rem;
    align-items: center;
    padding: 2rem 0;
    border-top: 1px solid rgba(10,10,10,0.1);
    text-decoration: none;
    color: var(--black);
    transition: gap 0.3s ease;
  }

  .features-list .feature-row:last-child {
    border-bottom: 1px solid rgba(10,10,10,0.1);
  }

  .feature-row:hover {
    gap: 2rem;
  }

  .feature-num {
    font-family: 'Syne', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    opacity: 0.3;
    padding-top: 0.15rem;
  }

  .feature-body h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
    transition: letter-spacing 0.3s ease;
  }

  .feature-row:hover .feature-body h3 {
    letter-spacing: 0.01em;
  }

  .feature-body p {
    font-size: 0.88rem;
    line-height: 1.65;
    color: rgba(10,10,10,0.55);
  }

  .feature-arrow {
    color: var(--black);
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    transform: translateX(-6px);
  }

  .feature-row:hover .feature-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── About ── */
  .about-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    padding: 6rem 4rem;
    background: var(--white);
    border-top: 1px solid rgba(10,10,10,0.08);
  }

  .about-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.76rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.42;
    margin-bottom: 1.2rem;
  }

  .about-content h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .about-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(10,10,10,0.65);
    margin-bottom: 1rem;
    max-width: 48ch;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    background: var(--black);
    color: var(--white);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    transition: opacity 0.25s ease;
  }
  .about-cta:hover { opacity: 0.8; }

  .about-image-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .about-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
    border-radius: 20px;
    position: relative;
    z-index: 1;
  }

  .about-image-blur {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(40px) saturate(1.4);
    transform: scale(1.1);
    opacity: 0.35;
    z-index: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .features-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .features-head p { max-width: 100%; }
    .about-section { grid-template-columns: 1fr; }
    .about-image { height: 360px; }
  }

  @media (max-width: 768px) {
    .features-section,
    .about-section {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }
</style>
