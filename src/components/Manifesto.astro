---
const lines = [
  "We verwijderen frictie.",
  "We automatiseren het werk.",
  "We engineeren groei.",
  "We bouwen digitale bedrijven.",
];
---

<section class="manifesto-section" data-bg-color="#000000">
  <div class="scene-grain" aria-hidden="true"></div>

  <div class="manifesto-pin">
    <div class="manifesto-lines">
      {lines.map((line, i) => (
        <p class="manifesto-line" data-index={i}>{line}</p>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function init() {
    const section = document.querySelector<HTMLElement>(".manifesto-section");
    const pin = section?.querySelector<HTMLElement>(".manifesto-pin");
    const lines = gsap.utils.toArray<HTMLElement>(".manifesto-line");
    if (!section || !pin || !lines.length) return;

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduced) {
      section.classList.add("is-static");
      return;
    }

    gsap.registerPlugin(ScrollTrigger);
    gsap.set(lines, { opacity: 0, y: 28 });
    gsap.set(lines[0], { opacity: 1, y: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: () => `+=${lines.length * 90}%`,
        scrub: 0.6,
        pin,
      },
    });

    lines.forEach((line, i) => {
      if (i > 0) {
        tl.to(lines[i - 1], { opacity: 0, y: -28, duration: 0.4 }, i);
        tl.fromTo(line, { opacity: 0, y: 28 }, { opacity: 1, y: 0, duration: 0.4 }, i + 0.1);
      }
      tl.to(line, { opacity: 1, y: 0, duration: 0.6 }, i + 0.5); // hold
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>

<style>
  .manifesto-section {
    position: relative;
    isolation: isolate;
    background: var(--void);
    overflow: hidden;
  }

  .manifesto-pin {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 4rem clamp(20px, 5vw, 56px);
  }

  .manifesto-lines {
    position: relative;
    display: grid;
    /* minmax(0, 1fr) instead of the implicit auto track — an auto track
       sizes to its content's max-content width, which is what let long
       lines overflow past the viewport despite width:100% below. */
    grid-template-columns: minmax(0, 1fr);
    place-items: center;
    width: 100%;
  }

  .manifesto-line {
    grid-area: 1 / 1;
    margin: 0;
    max-width: 100%;
    min-width: 0;
    overflow-wrap: break-word;
    text-align: center;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    font-size: clamp(2rem, 6vw, 4.4rem);
    color: var(--ink);
  }

  /* Baseline: only the first line shows until JS takes over, so a slow or
     failed script load never stacks all four sentences on top of each other. */
  .manifesto-line:not(:first-child) {
    opacity: 0;
  }

  .manifesto-section.is-static .manifesto-line:not(:first-child) {
    opacity: 0.85;
  }

  /* Reduced-motion fallback: plain stacked list, no pin/scrub */
  .manifesto-section.is-static .manifesto-pin {
    min-height: 0;
    padding: 6rem clamp(20px, 5vw, 56px);
  }

  .manifesto-section.is-static .manifesto-lines {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .manifesto-section.is-static .manifesto-line {
    grid-area: auto;
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .manifesto-pin { padding: 2.5rem 1.25rem; min-height: 70vh; }
  }
</style>
