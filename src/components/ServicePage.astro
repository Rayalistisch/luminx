---
import Footer from "./Footer.astro";
import ContactOverlay from "./ContactOverlay.astro";
import Nav from "./Nav.astro";

interface Metric {
  value: string;
  label: string;
}

interface RelatedRegion {
  label: string;
  href: string;
}

interface RelatedService {
  label: string;
  href: string;
  description?: string;
}

interface FAQ {
  q: string;
  a: string;
}

interface Props {
  title: string;
  intro: string;
  icon?: string;
  highlights: string[];
  process: string[];
  painPoints: string[];
  outcomes: string[];
  metrics: Metric[];
  relatedRegions?: RelatedRegion[];
  relatedServices?: RelatedService[];
  faq?: FAQ[];
  parentService?: { label: string; href: string };
}

const {
  title,
  intro,
  icon = "✦",
  highlights,
  process,
  painPoints,
  outcomes,
  metrics,
  relatedRegions,
  relatedServices,
  faq,
  parentService,
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://luminx.nl";
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: title,
  description: intro,
  serviceType: title,
  url: canonicalUrl,
  areaServed: relatedRegions?.length
    ? ["Twente", "Enschede", "Hengelo", "Almelo", "Oldenzaal"]
    : "NL",
  provider: {
    "@type": "Organization",
    "@id": `${siteOrigin}/#organization`,
    name: "LuminX",
    url: siteOrigin,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteOrigin },
    { "@type": "ListItem", position: 2, name: "Diensten", item: `${siteOrigin}/diensten` },
    { "@type": "ListItem", position: 3, name: title, item: canonicalUrl },
  ],
};

const faqSchema = faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
} : null;
---

<div class="cursor"></div>
<div class="cursor-follower"></div>
<Nav basePath="/" />
<script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}

<main class="service-page">
  <section class="service-hero" data-bg-color="#0A0A0A">
    <div class="service-hero-overlay" aria-hidden="true"></div>
    <div class="service-hero-grid">
      <div class="service-hero-content">
        {parentService
          ? <a href={parentService.href} class="service-back-link">← {parentService.label}</a>
          : <a href="/" class="service-back-link">Terug naar homepage</a>
        }
        <span class="service-kicker">Specialisme</span>
        <h1>
          <span class="service-icon" aria-hidden="true">{icon}</span>
          {title}
        </h1>
        <p>{intro}</p>

        <div class="service-hero-actions">
          <a href="#contact" class="service-primary-link">Plan kennismaking</a>
          <a href="#aanpak" class="service-secondary-link">Bekijk aanpak</a>
        </div>

        <div class="service-metrics">
          {metrics.map((metric) => (
            <article class="service-metric">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      </div>

      <aside class="service-intro-panel">
        <span>Wat je direct merkt</span>
        <ul>
          {outcomes.slice(0, 3).map((outcome) => <li>{outcome}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <section class="service-context" data-bg-color="#FEFEFE">
    <div class="service-context-grid">
      <article class="service-block">
        <h2>Waar organisaties op vastlopen</h2>
        <ul class="service-list service-list--muted">
          {painPoints.map((point) => <li>{point}</li>)}
        </ul>
      </article>

      <article class="service-block service-block--soft">
        <h2>Wat wij concreet opleveren</h2>
        <ul class="service-list">
          {highlights.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="service-approach" id="aanpak" data-bg-color="#F7F9FC">
    <div class="service-approach-head">
      <span>Aanpak</span>
      <h2>Van analyse naar implementatie in duidelijke fases.</h2>
    </div>

    <div class="service-approach-grid">
      {process.map((step, index) => (
        <article class="service-step">
          <span class="service-step-index">0{index + 1}</span>
          <p>{step}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="service-outcomes" data-bg-color="#0A0A0A">
    <div class="service-outcomes-inner">
      <h2>Resultaten die je mag verwachten</h2>
      <div class="service-outcome-tags">
        {outcomes.map((outcome) => <span>{outcome}</span>)}
      </div>
    </div>
  </section>

  {Astro.slots.has('body') && (
    <section class="service-body" data-bg-color="#FEFEFE">
      <div class="service-body-inner">
        <slot name="body" />
      </div>
    </section>
  )}

  {relatedRegions && relatedRegions.length > 0 && (
    <section class="service-regions" data-bg-color="#F7F9FC">
      <div class="service-regions-inner">
        <span class="service-regions-kicker">Regionale aanwezigheid</span>
        <h2>Actief in heel Twente</h2>
        <p>LuminX werkt voor bedrijven door heel Twente. Bekijk onze aanpak per regio.</p>
        <ul class="service-regions-grid">
          {relatedRegions.map((region) => (
            <li>
              <a href={region.href} class="service-region-card">
                <span>{region.label}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {relatedServices && relatedServices.length > 0 && (
    <section class="service-related" data-bg-color="#FEFEFE">
      <div class="service-related-inner">
        <span class="service-related-kicker">Gerelateerde diensten</span>
        <div class="service-related-grid">
          {relatedServices.map((s) => (
            <a href={s.href} class="service-related-card">
              <strong>{s.label}</strong>
              {s.description && <span>{s.description}</span>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {faq && faq.length > 0 && (
    <section class="service-faq" data-bg-color="#FEFEFE">
      <div class="service-faq-inner">
        <span class="service-faq-kicker">Veelgestelde vragen</span>
        <h2>Antwoorden op veelgestelde vragen</h2>
        <dl class="service-faq-list">
          {faq.map(({ q, a }) => (
            <div class="service-faq-item">
              <dt>{q}</dt>
              <dd>{a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <section class="cta-section" id="contact" data-bg-color="#0A0A0A">
    <div class="cta-content">
      <h2>Klaar Voor De<br/>Volgende Stap?</h2>
      <p>We vertalen jouw vraagstuk naar een praktisch plan met duidelijke prioriteiten, scope en resultaat.</p>
      <a href="#" class="cta-button" data-overlay-open>Plan kennismaking</a>
    </div>
  </section>

  <Footer />
  <ContactOverlay />
</main>

<style>
  .service-page {
    background: var(--white);
  }

  .service-hero {
    min-height: 88vh;
    position: relative;
    background: var(--black);
    color: var(--white);
    padding: 10rem 4rem 5.5rem;
    overflow: hidden;
  }

  .service-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 214, 232, 0.18), transparent 42%),
      radial-gradient(circle at 82% 24%, rgba(200, 231, 245, 0.14), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0));
  }

  .service-hero-grid {
    position: relative;
    z-index: 1;
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 2rem;
    align-items: end;
  }

  .service-back-link {
    display: inline-flex;
    margin-bottom: 1.8rem;
    color: var(--white);
    text-decoration: none;
    opacity: 0.7;
    font-size: 0.95rem;
    transition: opacity 0.25s ease;
  }

  .service-back-link:hover { opacity: 1; }

  .service-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.48;
    margin-bottom: 1rem;
  }

  .service-hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.6rem, 6vw, 5.4rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 1.4rem;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
  }

  .service-icon {
    color: var(--pastel-pink);
    font-size: 0.68em;
  }

  .service-hero p {
    max-width: 700px;
    font-size: clamp(1.04rem, 2.3vw, 1.3rem);
    opacity: 0.88;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .service-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .service-primary-link,
  .service-secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    padding: 0.9rem 1.45rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .service-primary-link {
    color: var(--black);
    background: var(--white);
  }

  .service-secondary-link {
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .service-primary-link:hover,
  .service-secondary-link:hover {
    transform: translateY(-2px);
  }

  .service-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
    max-width: 720px;
  }

  .service-metric {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding: 0.75rem 0;
    background: transparent;
  }

  .service-metric strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 1.25rem;
    margin-bottom: 0.2rem;
  }

  .service-metric span {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .service-intro-panel {
    border-left: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.5rem 0 0.5rem 1.5rem;
    background: transparent;
  }

  .service-intro-panel > span {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.58;
    margin-bottom: 0.75rem;
  }

  .service-intro-panel ul {
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  .service-intro-panel li {
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
    opacity: 0.92;
  }

  .service-intro-panel li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--pastel-pink), var(--pastel-blue));
    position: absolute;
    left: 0;
    top: 0.62rem;
  }

  .service-context {
    padding: 6rem 4rem;
  }

  .service-context-grid {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }

  .service-block {
    border-top: 1px solid rgba(10, 10, 10, 0.14);
    padding: 1.8rem 0 0;
    background: transparent;
  }

  .service-block--soft {
    border-top-color: rgba(10, 10, 10, 0.28);
  }

  .service-block h2 {
    font-family: 'Syne', sans-serif;
    font-size: 1.85rem;
    line-height: 1.06;
    margin-bottom: 1.2rem;
    max-width: 16ch;
  }

  .service-list {
    list-style: none;
    display: grid;
    gap: 0.8rem;
  }

  .service-list li {
    position: relative;
    padding-left: 1.1rem;
    line-height: 1.65;
    color: rgba(10, 10, 10, 0.84);
  }

  .service-list li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--black);
    position: absolute;
    left: 0;
    top: 0.64rem;
  }

  .service-list--muted li {
    color: rgba(10, 10, 10, 0.7);
  }

  .service-list--muted li::before {
    background: rgba(10, 10, 10, 0.42);
  }

  .service-approach {
    padding: 6rem 4rem;
  }

  .service-approach-head {
    max-width: 1240px;
    margin: 0 auto 2rem;
  }

  .service-approach-head > span {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 0.9rem;
  }

  .service-approach-head h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4.3vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    max-width: 18ch;
  }

  .service-approach-grid {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid rgba(10, 10, 10, 0.16);
    border-bottom: 1px solid rgba(10, 10, 10, 0.16);
  }

  .service-step {
    padding: 1.4rem 1.2rem 1.5rem;
    min-height: 190px;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    border-right: 1px solid rgba(10, 10, 10, 0.12);
  }

  .service-step:last-child {
    border-right: none;
  }

  .service-step-index {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    opacity: 0.52;
  }

  .service-step p {
    color: rgba(10, 10, 10, 0.8);
    line-height: 1.7;
  }

  .service-outcomes {
    padding: 6rem 4rem;
    background: var(--black);
    color: var(--white);
  }

  .service-outcomes-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .service-outcomes h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.4rem;
  }

  .service-outcome-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .service-outcome-tags span {
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 0;
    padding: 0.3rem 0;
    font-size: 0.9rem;
  }

  /* Body / article section */
  .service-body {
    padding: 6rem 4rem;
    background: var(--white);
  }

  .service-body-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .service-body-inner :global(h2) {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--black);
    margin: 2.5rem 0 1rem;
  }

  .service-body-inner :global(h2:first-child) {
    margin-top: 0;
  }

  .service-body-inner :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(10,10,10,0.75);
    margin-bottom: 1.2rem;
  }

  .service-body-inner :global(ul) {
    list-style: none;
    margin: 1rem 0 1.5rem;
    display: grid;
    gap: 0.6rem;
  }

  .service-body-inner :global(ul li) {
    position: relative;
    padding-left: 1.2rem;
    color: rgba(10,10,10,0.8);
    line-height: 1.65;
  }

  .service-body-inner :global(ul li)::before {
    content: "";
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--black);
    position: absolute;
    left: 0;
    top: 0.65rem;
  }

  .service-body-inner :global(a) {
    color: var(--black);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 0.2s ease;
  }

  .service-body-inner :global(a:hover) {
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .service-body { padding: 4rem 2rem; }
  }

  /* Regions section */
  .service-regions {
    padding: 6rem 4rem;
  }

  .service-regions-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .service-regions-kicker {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 0.9rem;
  }

  .service-regions h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.6rem;
  }

  .service-regions > div > p {
    color: rgba(10, 10, 10, 0.65);
    margin-bottom: 2rem;
  }

  .service-regions-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .service-region-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid rgba(10, 10, 10, 0.12);
    border-radius: 10px;
    text-decoration: none;
    color: var(--black);
    font-weight: 500;
    font-size: 0.95rem;
    background: var(--white);
    transition: border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .service-region-card:hover {
    border-color: var(--black);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(10, 10, 10, 0.08);
  }

  /* Related services section */
  .service-related {
    padding: 4rem 4rem;
  }

  .service-related-inner {
    max-width: 1240px;
    margin: 0 auto;
  }

  .service-related-kicker {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 1.2rem;
  }

  .service-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .service-related-card {
    display: block;
    padding: 1.4rem 1.6rem;
    border: 1px solid rgba(10, 10, 10, 0.12);
    border-radius: 10px;
    text-decoration: none;
    color: var(--black);
    transition: border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .service-related-card:hover {
    border-color: var(--black);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(10, 10, 10, 0.08);
  }

  .service-related-card strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .service-related-card span {
    font-size: 0.88rem;
    color: rgba(10, 10, 10, 0.6);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .service-related { padding: 3rem 2rem; }
  }

  /* FAQ section */
  .service-faq {
    padding: 6rem 4rem;
  }

  .service-faq-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .service-faq-kicker {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-bottom: 0.9rem;
  }

  .service-faq h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .service-faq-list {
    display: grid;
    gap: 0;
  }

  .service-faq-item {
    border-top: 1px solid rgba(10, 10, 10, 0.12);
    padding: 1.6rem 0;
  }

  .service-faq-item:last-child {
    border-bottom: 1px solid rgba(10, 10, 10, 0.12);
  }

  .service-faq-item dt {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.65rem;
    color: var(--black);
  }

  .service-faq-item dd {
    color: rgba(10, 10, 10, 0.72);
    line-height: 1.75;
    max-width: 70ch;
  }

  @media (max-width: 1100px) {
    .service-hero-grid {
      grid-template-columns: 1fr;
    }

    .service-context-grid,
    .service-approach-grid {
      grid-template-columns: 1fr 1fr;
    }

    .service-step:nth-child(2n) {
      border-right: none;
