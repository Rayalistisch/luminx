<script>
  (function () {
    const headline = document.querySelector<HTMLElement>('.hero-headline');
    if (!headline) return;

    const TRANSITION = 'transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94)';

    function makeSpan(ch: string): HTMLElement {
      const span = document.createElement('span');
      span.className = 'hc';
      span.textContent = ch;
      span.style.display = 'inline-block';
      span.style.transition = TRANSITION;
      span.style.willChange = 'transform';
      return span;
    }

    function makeEmSpan(ch: string): HTMLElement {
      // Two-span structure for <em> characters:
      //  outer = display:inline-block  → handles transform
      //  inner = display:inline        → background-clip:text works over full glyph height
      // line-height:1.3 on outer makes the inner line box tall enough to cover italic ascenders.
      const outer = document.createElement('span');
      outer.className = 'hc';
      outer.style.display = 'inline-block';
      outer.style.lineHeight = '1.3';
      outer.style.transition = TRANSITION;
      outer.style.willChange = 'transform';

      const inner = document.createElement('span');
      inner.textContent = ch;
      inner.style.background = 'linear-gradient(135deg, var(--pastel-pink), var(--pastel-blue))';
      inner.style.backgroundClip = 'text';
      (inner.style as any).webkitBackgroundClip = 'text';
      (inner.style as any).webkitTextFillColor = 'transparent';

      outer.appendChild(inner);
      return outer;
    }

    // Split text nodes into per-character spans; recurse into elements except <br>.
    // Passes inEm=true when inside <em> so the correct span type is created.
    function splitNode(node: Node, inEm: boolean) {
      if (node.nodeType === Node.TEXT_NODE) {
        const frag = document.createDocumentFragment();
        for (const ch of (node.textContent ?? '')) {
          if (ch === ' ' || ch === '\n') {
            frag.appendChild(document.createTextNode(ch));
          } else {
            frag.appendChild(inEm ? makeEmSpan(ch) : makeSpan(ch));
          }
        }
        node.replaceWith(frag);
      } else if (node.nodeType === Node.ELEMENT_NODE && (node as Element).tagName !== 'BR') {
        const nextInEm = inEm || (node as Element).tagName === 'EM';
        Array.from(node.childNodes).forEach(n => splitNode(n, nextInEm));
      }
    }

    Array.from(headline.childNodes).forEach(n => splitNode(n, false));

    // Remove <em>'s own gradient — it's now applied per inner span.
    headline.querySelectorAll<HTMLElement>('em').forEach((em) => {
      em.style.background = 'none';
      em.style.backgroundClip = 'unset';
      (em.style as any).webkitBackgroundClip = 'unset';
      (em.style as any).webkitTextFillColor = 'inherit';
    });

    const RADIUS = 130;
    const STRENGTH = 60;
    const MAX_ROT = 22;
    const MAX_SCALE = 0.28;

    function onMove(e: MouseEvent) {
      headline.querySelectorAll<HTMLElement>('.hc').forEach((span) => {
        const rect = span.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < RADIUS && dist > 0.5) {
          const force = 1 - dist / RADIUS;
          const tx = -(dx / dist) * STRENGTH * force;
          const ty = -(dy / dist) * STRENGTH * force;
          const rot = (dx / dist) * MAX_ROT * force;
          const sc = 1 + MAX_SCALE * force;
          span.style.transform = `translate(${tx}px, ${ty}px) rotate(${rot}deg) scale(${sc})`;
        } else {
          span.style.transform = '';
        }
      });
    }

    function onLeave() {
      headline.querySelectorAll<HTMLElement>('.hc').forEach((span) => {
        span.style.transform = '';
      });
    }

    if (window.matchMedia?.('(hover: hover)').matches) {
      window.addEventListener('mousemove', onMove, { passive: true });
      const heroSection = document.querySelector<HTMLElement>('.hero');
      heroSection?.addEventListener('mouseleave', onLeave);
    }
  })();
</script>
