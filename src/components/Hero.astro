---
import HeroShutterText from "./ui/hero-shutter-text";
---

<section class="hero" data-bg-color="#0A0A0A">

  <!-- Atmospheric glow -->
  <div class="hero-glow" aria-hidden="true"></div>

  <!-- Giant watermark -->
  <p class="hero-watermark" aria-hidden="true">LUMINX</p>

  <!-- Main content -->
  <div class="hero-content">
    <span class="hero-kicker">Digital Marketing Bureau · Enschede</span>
    <HeroShutterText client:load />
    <p class="hero-sub">Meer zichtbaarheid, meer leads, slimmere processen.<br> Voor MKB'ers die online willen groeien.</p>
    <div class="hero-actions">
      <a href="#" class="hero-cta" data-overlay-open>Plan een kennismaking</a>
      <button type="button" class="hero-scan-btn" data-seoscan-open>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Gratis SEO scan
      </button>
    </div>
  </div>

  <!-- Bottom-left descriptor -->
  <div class="hero-descriptor">
    <p>Voor ambitieuze ondernemers<br/>die online willen groeien.</p>
  </div>



  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <span></span>
    <p>SCROLL</p>
  </div>

</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background: var(--black);
    color: var(--white);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ── Atmospheric glow ── */
  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 60% at 28% 52%, rgba(255, 214, 232, 0.11), transparent 68%),
      radial-gradient(ellipse 50% 40% at 78% 38%, rgba(200, 231, 245, 0.08), transparent 65%);
  }

  /* ── Giant watermark ── */
  .hero-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Syne', sans-serif;
    font-weight: 900;
    font-size: clamp(18vw, 24vw, 28vw);
    letter-spacing: -0.045em;
    line-height: 1;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.038);
    pointer-events: none;
    user-select: none;
  }

  /* ── Main content ── */
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 4rem;
    max-width: 1240px;
    margin: 0 auto;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-kicker {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.74rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 1.5rem;
  }


  .hero-sub {
    max-width: 46ch;
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    line-height: 1.75;
    opacity: 0.65;
    margin-top: 1.5rem;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
    z-index: 10;
  }

  .hero-cta,
  .hero-scan-btn {
    touch-action: manipulation;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    background: var(--white);
    color: var(--black);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(255, 255, 255, 0.12);
  }

  .hero-scan-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: transparent;
    color: var(--white);
    border: 1.5px solid rgba(255,255,255,0.25);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.9rem 1.5rem;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .hero-scan-btn:hover {
    border-color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.06);
  }

  .hero-link {
    color: var(--white);
    text-decoration: none;
    font-size: 0.9rem;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }
  .hero-link:hover { opacity: 1; }

  /* ── Bottom-left descriptor ── */
  .hero-descriptor {
    position: absolute;
    bottom: 3.5rem;
    left: 4rem;
    z-index: 2;
  }
  .hero-descriptor p {
    font-size: 0.78rem;
    line-height: 1.7;
    opacity: 0.38;
    letter-spacing: 0.02em;
  }

  /* ── Floating badge card ── */
  .hero-badge {
    position: absolute;
    bottom: 3.5rem;
    right: 4rem;
    z-index: 2;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 18px;
    padding: 1.5rem 1.75rem;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    min-width: 180px;
  }

  .hero-badge-label {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.45;
    margin-bottom: 0.5rem;
  }

  .hero-badge-num {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, var(--pastel-pink), var(--pastel-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.3rem;
  }

  .hero-badge-sub {
    display: block;
    font-size: 0.75rem;
    opacity: 0.5;
    margin-bottom: 1.1rem;
  }

  .hero-badge-link {
    display: inline-block;
    font-family: 'Syne', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.22);
    padding-bottom: 1px;
    transition: opacity 0.2s ease;
  }
  .hero-badge-link:hover { opacity: 0.6; }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    position: absolute;
    bottom: 3.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
  }

  .scroll-indicator span {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0.3));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  .scroll-indicator p {
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    opacity: 0.3;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }


  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-descriptor { display: none; }
    .hero-badge { right: 2rem; }
  }

  @media (max-width: 768px) {
    .hero-content {
      padding: 9rem 2rem 12rem;
    }
    .hero-content h1 {
      font-size: clamp(2rem, 11vw, 4.5rem);
    }
    .hero-badge {
      right: 2rem;
      bottom: 4rem;
      padding: 1.25rem;
    }
    .hero-badge-num { font-size: 2rem; }
    .scroll-indicator { display: none; }
  }
</style>

