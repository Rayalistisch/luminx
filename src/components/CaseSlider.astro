---
interface Slide {
  src: string;
  alt: string;
  title?: string;
  desc?: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<div class="cs-wrap">
  <div class="cs-track" id="caseSlider">
    {slides.map((slide, i) => (
      <div
        class="cs-card"
        data-index={i}
        {...(i === 0 ? { "data-active": "" } : {})}
        role="button"
        tabindex="0"
        aria-label={slide.title ?? slide.alt}
      >
        <img
          class="cs-card-img"
          src={slide.src}
          alt={slide.alt}
          loading="lazy"
          decoding="async"
        />
        <div class="cs-card-overlay" />
        <span class="cs-card-label">{slide.title ?? slide.alt}</span>
        {(slide.title || slide.desc) && (
          <div class="cs-card-info">
            {slide.title && <strong class="cs-card-title">{slide.title}</strong>}
            {slide.desc && <p class="cs-card-desc">{slide.desc}</p>}
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="cs-nav">
    <button class="cs-btn cs-btn-prev" id="csPrev" aria-label="Vorige">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <div class="cs-dots" id="csDots">
      {slides.map((_, i) => (
        <button
          class="cs-dot"
          data-dot={i}
          aria-label={`Slide ${i + 1}`}
          {...(i === 0 ? { "data-dot-active": "" } : {})}
        />
      ))}
    </div>

    <button class="cs-btn cs-btn-next" id="csNext" aria-label="Volgende">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
</div>

<script>
  const track = document.getElementById('caseSlider')!;
  const prev  = document.getElementById('csPrev')!;
  const next  = document.getElementById('csNext')!;
  const dots  = document.getElementById('csDots')!;

  const cards = Array.from(track.querySelectorAll<HTMLElement>('.cs-card'));
  const dotBtns = Array.from(dots.querySelectorAll<HTMLButtonElement>('.cs-dot'));

  let current = 0;
  let hoverTimer: ReturnType<typeof setTimeout> | null = null;

  function activate(idx: number) {
    if (idx === current) return;
    cards[current].removeAttribute('data-active');
    dotBtns[current].removeAttribute('data-dot-active');
    current = idx;
    cards[current].setAttribute('data-active', '');
    dotBtns[current].setAttribute('data-dot-active', '');
  }

  prev.addEventListener('click', () => activate((current - 1 + cards.length) % cards.length));
  next.addEventListener('click', () => activate((current + 1) % cards.length));

  dotBtns.forEach((dot, i) => {
    dot.addEventListener('click', () => activate(i));
  });

  cards.forEach((card, i) => {
    card.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(() => activate(i), 120);
    });
    card.addEventListener('mouseleave', () => {
      if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
    });
    card.addEventListener('click', () => activate(i));
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') activate(i);
    });
  });

  track.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'ArrowRight') activate((current + 1) % cards.length);
    if (e.key === 'ArrowLeft')  activate((current - 1 + cards.length) % cards.length);
  });

  // Touch swipe
  let touchX = 0;
  track.addEventListener('touchstart', (e: TouchEvent) => { touchX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e: TouchEvent) => {
    const diff = touchX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) {
      activate(diff > 0
        ? (current + 1) % cards.length
        : (current - 1 + cards.length) % cards.length
      );
    }
  });
</script>

<style>
  .cs-wrap {
    width: 100%;
    padding: 0 4rem 4rem;
    max-width: 1240px;
    margin: 0 auto;
    box-sizing: border-box;
  }

  .cs-track {
    display: flex;
    gap: 0.6rem;
    height: 620px;
    align-items: stretch;
  }

  .cs-card {
    --closed: 4.5rem;
    --open: 999px; /* flex will cap at available space */

    position: relative;
    flex: 0 1 var(--closed);
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: flex-basis 0.55s cubic-bezier(0.77, 0, 0.175, 1);
    outline: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cs-card[data-active] {
    flex: 1 1 var(--open);
  }

  /* Screenshot fills the card */
  .cs-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.55s ease;
  }

  .cs-card[data-active] .cs-card-img {
    transform: scale(1.015);
  }

  /* Dark gradient overlay */
  .cs-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.25) 0%,
      rgba(10, 10, 10, 0.0) 40%,
      rgba(10, 10, 10, 0.72) 100%
    );
    transition: opacity 0.4s ease;
  }

  .cs-card:not([data-active]) .cs-card-overlay {
    background: rgba(10, 10, 10, 0.62);
  }

  /* Vertical label on closed cards */
  .cs-card-label {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%) rotate(-90deg);
    transform-origin: center center;
    white-space: nowrap;
    font-family: 'Syne', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .cs-card[data-active] .cs-card-label {
    opacity: 0;
  }

  /* Info block on active card */
  .cs-card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.8rem 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.35s ease 0.15s, transform 0.35s ease 0.15s;
    pointer-events: none;
  }

  .cs-card[data-active] .cs-card-info {
    opacity: 1;
    transform: translateY(0);
  }

  .cs-card-title {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: clamp(1rem, 1.6vw, 1.35rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 0.45rem;
  }

  .cs-card-desc {
    font-size: 0.84rem;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.55;
    max-width: 42ch;
  }

  /* Navigation */
  .cs-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.4rem;
  }

  .cs-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid rgba(10, 10, 10, 0.2);
    border-radius: 50%;
    background: none;
    color: var(--black);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .cs-btn:hover {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  .cs-dots {
    display: flex;
    gap: 0.45rem;
    align-items: center;
  }

  .cs-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(10, 10, 10, 0.2);
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .cs-dot[data-dot-active] {
    background: var(--black);
    transform: scale(1.4);
  }

  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    .cs-wrap {
      padding: 0 2rem 3rem;
    }

    .cs-track {
      flex-direction: column;
      height: auto;
      gap: 0.5rem;
    }

    .cs-card {
      flex: none !important;
      height: 4.5rem;
      border-radius: 10px;
      transition: height 0.5s cubic-bezier(0.77, 0, 0.175, 1);
    }

    .cs-card[data-active] {
      height: 400px;
    }

    .cs-card-label {
      transform: translateX(-50%);
      left: 50%;
      bottom: auto;
      top: 50%;
      transform: translate(-50%, -50%);
    }
  }
</style>
