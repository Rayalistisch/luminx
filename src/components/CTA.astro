<script is:inline>
  (function () {
    var calendarUrl = "https://calendar.google.com/calendar/appointments/schedules/AcZssZ0KnPaRiH37bvNSB0ta7HrOtyHk8wT8EUaAMULRWJcV8kywKhl-TEVeRu1YsOLCFd3vzfBt6dve?gv=true";
    var tries = 0;

    function initCtaCalendarButton() {
      var slot = document.getElementById("cta-calendar-button-slot");
      if (!slot || slot.dataset.initialized === "true") return;
      if (!window.calendar || !window.calendar.schedulingButton) return;

      window.calendar.schedulingButton.load({
        url: calendarUrl,
        color: "#A79B8E",
        label: "Plan een videocall",
        target: slot,
      });

      slot.dataset.initialized = "true";
      slot.classList.add("is-ready");
    }

    function initWithRetry() {
      var timer = window.setInterval(function () {
        tries += 1;
        initCtaCalendarButton();
        var slot = document.getElementById("cta-calendar-button-slot");
        if ((slot && slot.dataset.initialized === "true") || tries >= 40) {
          window.clearInterval(timer);
        }
      }, 100);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initWithRetry);
    } else {
      initWithRetry();
    }
  })();
</script>

