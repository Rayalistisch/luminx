<section class="cta-section" id="contact">
  <div class="cta-glow" aria-hidden="true"></div>

  <div class="cta-content">
    <span class="cta-kicker">Klaar om te groeien?</span>
    <h2>Laten we iets<br/>moois bouwen</h2>
    <p>Plan een vrijblijvend kennismakingsgesprek en ontdek wat we samen kunnen bereiken.</p>
    <a href="#" class="cta-button" data-overlay-open>Plan een gesprek</a>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background: #0A0A0A;
    overflow: hidden;
    padding: 10rem 2rem 8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  /* Gradient glow blob */
  .cta-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 30% 60%, rgba(255, 182, 193, 0.18) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 75% 40%, rgba(173, 216, 230, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-kicker {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .cta-content h2 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
  }

  .cta-content p {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    max-width: 460px;
    margin: 0;
  }

  .cta-button {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 1rem 2.4rem;
    background: linear-gradient(135deg, var(--pastel-pink), var(--pastel-blue));
    color: #0A0A0A;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 100px;
    transition: opacity 0.2s, transform 0.2s;
  }

  .cta-button:hover {
    opacity: 0.88;
    transform: translateY(-2px);
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>(".cta-section");
  if (section) {
    // Start squished and below — bounces into its natural shape on scroll
    gsap.fromTo(
      section,
      {
        scaleY: 0.6,
        scaleX: 1.08,
        y: 80,
        transformOrigin: "bottom center",
        opacity: 0,
      },
      {
        scaleY: 1,
        scaleX: 1,
        y: 0,
        opacity: 1,
        ease: "elastic.out(1, 0.45)",
        duration: 1.4,
        scrollTrigger: {
          trigger: section,
          start: "top 88%",
          toggleActions: "play none none none",
        },
      }
    );

    // Content fades up slightly after the section bounce
    gsap.fromTo(
      ".cta-content",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.7,
        ease: "power2.out",
        delay: 0.25,
        scrollTrigger: {
          trigger: section,
          start: "top 88%",
          toggleActions: "play none none none",
        },
      }
    );
  }
</script>
