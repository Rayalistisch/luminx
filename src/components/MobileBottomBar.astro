---
const whatsappNumber = "31613698596";
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent("Hi LuminX, ik wil graag meer informatie.")}`;
---

<div class="mobile-bottom-bar">
  <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="mbb-btn mbb-whatsapp">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M19.05 4.94A9.9 9.9 0 0 0 12.02 2C6.5 2 2 6.49 2 12a9.9 9.9 0 0 0 1.36 5.01L2 22l5.13-1.34A9.9 9.9 0 0 0 12.02 22c5.52 0 10.01-4.49 10.01-10a9.93 9.93 0 0 0-2.98-7.06Zm-7.03 15.4a8.3 8.3 0 0 1-4.22-1.15l-.3-.18-3.04.8.81-2.97-.2-.31A8.29 8.29 0 0 1 3.7 12c0-4.58 3.73-8.3 8.32-8.3a8.3 8.3 0 0 1 8.3 8.3 8.31 8.31 0 0 1-8.3 8.34Zm4.55-6.22c-.25-.12-1.48-.73-1.71-.81-.23-.09-.4-.12-.57.12-.17.24-.65.81-.8.98-.15.17-.3.18-.56.06-.25-.13-1.08-.4-2.05-1.26-.76-.68-1.28-1.52-1.43-1.77-.15-.24-.02-.37.11-.5.12-.12.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.32-.02-.45-.06-.12-.57-1.37-.78-1.88-.21-.5-.43-.43-.57-.44h-.49c-.17 0-.45.06-.68.32-.23.25-.88.86-.88 2.09 0 1.23.9 2.42 1.02 2.59.13.17 1.77 2.7 4.29 3.79.6.26 1.07.41 1.43.52.6.19 1.14.16 1.57.1.48-.07 1.48-.6 1.69-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.29Z"/>
    </svg>
    WhatsApp
  </a>
  <a href="#" class="mbb-btn mbb-afspraak" data-overlay-open>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    Plan Afspraak
  </a>
</div>

<style>
  .mobile-bottom-bar {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-bottom-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 9000;
      padding-bottom: env(safe-area-inset-bottom);
    }

    .mbb-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 1rem;
      font-family: 'Syne', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: opacity 0.2s ease;
    }

    .mbb-btn:active {
      opacity: 0.85;
    }

    .mbb-whatsapp {
      background: #1a1f2e;
      color: #fff;
    }

    .mbb-afspraak {
      background: #25d366;
      color: #fff;
    }
  }
</style>
