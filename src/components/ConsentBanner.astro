<div class="consent-widget" data-consent-widget hidden>
  <div class="consent-banner" role="dialog" aria-live="polite" aria-label="Cookievoorkeuren">
    <h3>Deze website gebruikt cookies</h3>
    <p>We gebruiken cookies voor analytics en marketing om de website te verbeteren.</p>

    <div class="consent-preferences" data-consent-preferences hidden>
      <label class="consent-pref-item">
        <span>
          <strong>Analytics</strong>
          <small>Helpt ons prestaties en gebruik te meten.</small>
        </span>
        <input type="checkbox" data-consent-analytics />
      </label>

      <label class="consent-pref-item">
        <span>
          <strong>Marketing</strong>
          <small>Voor advertentie-metingen en personalisatie.</small>
        </span>
        <input type="checkbox" data-consent-marketing />
      </label>
    </div>

    <div class="consent-actions">
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-customize>Aanpassen</button>
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-save hidden>Opslaan</button>
      <button type="button" class="consent-btn consent-btn--primary" data-consent-accept>Alles toestaan</button>
    </div>
  </div>

  <button type="button" class="consent-manage" data-consent-manage aria-label="Cookie-instellingen" hidden>
    <img src="/favicon.png" alt="" aria-hidden="true" />
  </button>
</div>

<script is:inline>
  (() => {
    const CONSENT_KEY = "luminx_consent_v1";
    const root = document.querySelector("[data-consent-widget]");
    if (!root) return;

    const banner = root.querySelector(".consent-banner");
    const acceptBtn = root.querySelector("[data-consent-accept]");
    const customizeBtn = root.querySelector("[data-consent-customize]");
    const saveBtn = root.querySelector("[data-consent-save]");
    const prefWrap = root.querySelector("[data-consent-preferences]");
    const analyticsInput = root.querySelector("[data-consent-analytics]");
    const marketingInput = root.querySelector("[data-consent-marketing]");
    const manageBtn = root.querySelector("[data-consent-manage]");

    function getStoredConsent() {
      try {
        const raw = localStorage.getItem(CONSENT_KEY);
        if (!raw) return null;
        if (raw === "granted") return { analytics: true, marketing: true };
        if (raw === "denied") return { analytics: false, marketing: false };
        return JSON.parse(raw);
      } catch (_e) {
        return null;
      }
    }

    function persistConsent(prefs) {
      try {
        localStorage.setItem(CONSENT_KEY, JSON.stringify(prefs));
      } catch (_e) {
        // ignore storage failures
      }
    }

    function toPayload(prefs) {
      const analytics = prefs?.analytics ? "granted" : "denied";
      const marketing = prefs?.marketing ? "granted" : "denied";
      return {
        ad_storage: marketing,
        analytics_storage: analytics,
        ad_user_data: marketing,
        ad_personalization: marketing,
        functionality_storage: "granted",
        security_storage: "granted",
      };
    }

    function updateConsent(prefs, mode) {
      const payload = toPayload(prefs);
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };
      window.gtag("consent", "update", payload);
      window.dataLayer.push({
        event: "consent_update",
        consent_mode: mode,
      });
    }

    function syncInputs(prefs) {
      if (analyticsInput) analyticsInput.checked = !!prefs?.analytics;
      if (marketingInput) marketingInput.checked = !!prefs?.marketing;
    }

    function openPreferences() {
      if (analyticsInput) analyticsInput.checked = true;
      if (marketingInput) marketingInput.checked = true;
      if (prefWrap) prefWrap.hidden = false;
      if (saveBtn) saveBtn.hidden = false;
      if (customizeBtn) customizeBtn.hidden = true;
    }

    function closePreferences() {
      if (prefWrap) prefWrap.hidden = true;
      if (saveBtn) saveBtn.hidden = true;
      if (customizeBtn) customizeBtn.hidden = false;
    }

    function openBanner() {
      root.hidden = false;
      banner?.classList.add("is-open");
      if (manageBtn) manageBtn.hidden = true;
      closePreferences();
    }

    function closeBanner() {
      banner?.classList.remove("is-open");
      if (manageBtn) manageBtn.hidden = false;
      closePreferences();
    }

    function applyChoice(prefs, mode) {
      persistConsent(prefs);
      updateConsent(prefs, mode);
      closeBanner();
    }

    const stored = getStoredConsent() || { analytics: false, marketing: false };
    syncInputs(stored);
    root.hidden = false;
    if (getStoredConsent()) {
      closeBanner();
    } else {
      openBanner();
    }

    acceptBtn?.addEventListener("click", () => applyChoice({ analytics: true, marketing: true }, "granted"));
    customizeBtn?.addEventListener("click", openPreferences);
    saveBtn?.addEventListener("click", () => {
      const prefs = {
        analytics: !!analyticsInput?.checked,
        marketing: !!marketingInput?.checked,
      };
      applyChoice(prefs, "custom");
    });
    manageBtn?.addEventListener("click", () => {
      syncInputs(getStoredConsent() || { analytics: false, marketing: false });
      openBanner();
    });
  })();
</script>

<style>
  .consent-widget {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 100000;
    pointer-events: none;
  }

  .consent-banner {
    pointer-events: auto;
    max-width: 700px;
    margin: 0 auto;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(10, 10, 10, 0.94);
    color: #fff;
    padding: 1rem;
    display: none;
    gap: 0.9rem;
  }

  .consent-banner.is-open {
    display: grid;
  }

  .consent-banner h3 {
    margin: 0;
    font-size: 1.1rem;
    font-family: "Syne", sans-serif;
    color: #fff;
  }

  .consent-banner p {
    margin: 0;
    max-width: 640px;
    font-size: 0.92rem;
    line-height: 1.5;
    opacity: 0.9;
  }

  .consent-preferences {
    display: grid;
    gap: 0.6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 0.8rem;
  }

  .consent-preferences[hidden] {
    display: none;
  }

  .consent-pref-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .consent-pref-item strong {
    display: block;
    font-size: 0.9rem;
  }

  .consent-pref-item small {
    display: block;
    opacity: 0.76;
    font-size: 0.78rem;
    margin-top: 0.12rem;
  }

  .consent-pref-item input {
    width: 18px;
    height: 18px;
  }

  .consent-actions {
    display: flex;
    gap: 0.65rem;
    width: 100%;
    justify-content: flex-end;
    align-items: center;
  }

  .consent-btn {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.72rem 1.2rem;
    min-height: 46px;
    min-width: 150px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }

  .consent-btn[hidden] {
    display: none;
  }

  .consent-btn--ghost {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.34);
    color: #fff;
  }

  .consent-btn--primary {
    background: #fff;
    color: #0a0a0a;
    min-width: 180px;
  }

  .consent-manage {
    pointer-events: auto;
    margin-left: 0;
    margin-right: auto;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(10, 10, 10, 0.18);
    background: rgba(255, 255, 255, 0.95);
    color: #0a0a0a;
    padding: 0;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .consent-manage img {
    width: 35px;
    height: 35px;
    border-radius: 50%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    /* Push banner above the mobile bottom bar */
    .consent-widget {
      top: auto;
      left: 1rem;
      right: 1rem;
      bottom: calc(80px + env(safe-area-inset-bottom));
    }

    .consent-banner {
      align-items: stretch;
      margin: 0;
      width: 100%;
      max-width: 100%;
    }

    .consent-actions {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr;
    }

    .consent-btn {
      width: 100%;
    }

    /* Cookie manage button: fixed left-center, independent of banner */
    .consent-manage {
      position: fixed;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      bottom: auto;
      margin: 0;
    }
  }
</style>
