<div class="consent-widget" data-consent-widget hidden>
  <div class="consent-banner" role="dialog" aria-live="polite" aria-label="Cookievoorkeuren">
    <p>
      We gebruiken cookies voor analytics en marketing om de website te verbeteren.
      Kies wat je wilt toestaan.
    </p>
    <div class="consent-actions">
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-reject>Weigeren</button>
      <button type="button" class="consent-btn consent-btn--primary" data-consent-accept>Accepteren</button>
    </div>
  </div>

  <button type="button" class="consent-manage" data-consent-manage hidden>
    Cookie-instellingen
  </button>
</div>

<script is:inline>
  (() => {
    const CONSENT_KEY = "luminx_consent_v1";
    const root = document.querySelector("[data-consent-widget]");
    if (!root) return;

    const banner = root.querySelector(".consent-banner");
    const acceptBtn = root.querySelector("[data-consent-accept]");
    const rejectBtn = root.querySelector("[data-consent-reject]");
    const manageBtn = root.querySelector("[data-consent-manage]");

    const granted = {
      ad_storage: "granted",
      analytics_storage: "granted",
      ad_user_data: "granted",
      ad_personalization: "granted",
      functionality_storage: "granted",
      security_storage: "granted",
    };

    const denied = {
      ad_storage: "denied",
      analytics_storage: "denied",
      ad_user_data: "denied",
      ad_personalization: "denied",
      functionality_storage: "granted",
      security_storage: "granted",
    };

    function getStoredConsent() {
      try {
        return localStorage.getItem(CONSENT_KEY);
      } catch (_e) {
        return null;
      }
    }

    function persistConsent(value) {
      try {
        localStorage.setItem(CONSENT_KEY, value);
      } catch (_e) {
        // ignore storage failures
      }
    }

    function updateConsent(mode) {
      const payload = mode === "granted" ? granted : denied;
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };
      window.gtag("consent", "update", payload);
      window.dataLayer.push({
        event: "consent_update",
        consent_mode: mode,
      });
    }

    function openBanner() {
      root.hidden = false;
      banner?.classList.add("is-open");
      if (manageBtn) manageBtn.hidden = true;
    }

    function closeBanner() {
      banner?.classList.remove("is-open");
      if (manageBtn) manageBtn.hidden = false;
    }

    function applyChoice(mode) {
      persistConsent(mode);
      updateConsent(mode);
      closeBanner();
    }

    const stored = getStoredConsent();
    root.hidden = false;
    if (stored === "granted" || stored === "denied") {
      closeBanner();
    } else {
      openBanner();
    }

    acceptBtn?.addEventListener("click", () => applyChoice("granted"));
    rejectBtn?.addEventListener("click", () => applyChoice("denied"));
    manageBtn?.addEventListener("click", openBanner);
  })();
</script>

<style>
  .consent-widget {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 100000;
    pointer-events: none;
  }

