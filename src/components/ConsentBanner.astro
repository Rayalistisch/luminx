    pointer-events: auto;
    max-width: 700px;
    margin: 0 auto;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(10, 10, 10, 0.94);
    color: #fff;
    padding: 1rem;
    display: none;
    gap: 0.85rem;
    align-items: center;
    justify-content: space-between;
  }

  .consent-banner.is-open {
    display: flex;
  }

  .consent-banner p {
    margin: 0;
    max-width: 520px;
    font-size: 0.92rem;
    line-height: 1.5;
    opacity: 0.9;
  }

  .consent-actions {
    display: inline-flex;
    gap: 0.55rem;
    flex-shrink: 0;
  }

  .consent-btn {
    border: 1px solid transparent;
    border-radius: 999px;
    padding: 0.62rem 1rem;
    font-size: 0.86rem;
    cursor: pointer;
  }

  .consent-btn--ghost {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.34);
    color: #fff;
  }

  .consent-btn--primary {
    background: #fff;
    color: #0a0a0a;
  }

  .consent-manage {
    pointer-events: auto;
    margin-left: 0;
    margin-right: auto;
    border-radius: 999px;
    border: 1px solid rgba(10, 10, 10, 0.18);
    background: rgba(255, 255, 255, 0.95);
    color: #0a0a0a;
    padding: 0.5rem 0.85rem;
    font-size: 0.78rem;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
  }

  @media (max-width: 768px) {
    .consent-banner {
      flex-direction: column;
      align-items: stretch;
    }
    .consent-actions {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .consent-btn {
      width: 100%;
    }
  }
</style>
