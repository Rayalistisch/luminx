---
import "../styles/globals.css";
import WhatsAppChat from "../components/WhatsAppChat.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import MobileBottomBar from "../components/MobileBottomBar.astro";
const {
  title,
  description,
  robots = "index,follow,max-image-preview:large",
  ogImage = "/images/luminx-founder.png",
  structuredData,
} = Astro.props;

const siteOrigin = (Astro.site?.toString() ?? "https://luminx.nl").replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();
const founderSchema = {
  "@type": "Person",
  "@id": `${siteOrigin}/#ray`,
  name: "Ray Huffenreuter",
  jobTitle: "Oprichter & Digital Strategist",
  url: siteOrigin,
  email: "hello@luminx.nl",
  worksFor: { "@id": `${siteOrigin}/#organization` },
};
const organizationSchema = {
  "@type": "Organization",
  "@id": `${siteOrigin}/#organization`,
  name: "LuminX",
  legalName: "LuminX",
  url: siteOrigin,
  email: "hello@luminx.nl",
  telephone: "+31613698596",
  logo: {
    "@type": "ImageObject",
    url: `${siteOrigin}/images/luminx-founder.png`,
  },
  founder: { "@id": `${siteOrigin}/#ray` },
  description: "LuminX is een digitaal bureau in Enschede, Twente. Wij helpen MKB-bedrijven groeien via SEO, Google Ads, social advertising, e-mailmarketing, procesautomatisering en webdevelopment.",
  areaServed: [
    { "@type": "City", name: "Enschede" },
    { "@type": "City", name: "Hengelo" },
    { "@type": "City", name: "Almelo" },
    { "@type": "City", name: "Oldenzaal" },
    { "@type": "AdministrativeArea", name: "Twente" },
  ],
  knowsAbout: ["SEO", "Google Ads", "Online Marketing", "Social Advertising", "E-mailmarketing", "Webdevelopment", "Procesautomatisering"],
  sameAs: [],
};
const websiteSchema = {
  "@type": "WebSite",
  "@id": `${siteOrigin}/#website`,
  url: siteOrigin,
  name: "LuminX",
  publisher: {
    "@id": `${siteOrigin}/#organization`,
  },
};
const webpageSchema = {
  "@type": "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: title,
  description,
  isPartOf: {
    "@id": `${siteOrigin}/#website`,
  },
  about: {
    "@id": `${siteOrigin}/#organization`,
  },
};
const additionalSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [founderSchema, organizationSchema, websiteSchema, webpageSchema, ...additionalSchemas],
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LuminX" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function () {
          window.dataLayer.push(arguments);
        };

      // EER + VK: toestemming vereist (GDPR)
      window.gtag("consent", "default", {
        ad_storage: "denied",
        analytics_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        functionality_storage: "granted",
        security_storage: "granted",
        wait_for_update: 500,
        region: ["AT","BE","BG","HR","CY","CZ","DK","EE","FI","FR","DE","GR","HU","IS","IE","IT","LV","LI","LT","LU","MT","NL","NO","PL","PT","RO","SK","SI","ES","SE","GB","CH"]
      });

      // Buiten EER: standaard toestemming verlenen
      window.gtag("consent", "default", {
        ad_storage: "granted",
        analytics_storage: "granted",
        ad_user_data: "granted",
        ad_personalization: "granted",
        functionality_storage: "granted",
        security_storage: "granted"
      });

      try {
        var storedConsent = localStorage.getItem("luminx_consent_v1");
        if (storedConsent) {
          var prefs = null;
          if (storedConsent === "granted") {
            prefs = { analytics: true, marketing: true };
          } else if (storedConsent === "denied") {
            prefs = { analytics: false, marketing: false };
          } else {
            prefs = JSON.parse(storedConsent);
          }

          if (prefs) {
            var analyticsStorage = prefs.analytics ? "granted" : "denied";
            var marketingStorage = prefs.marketing ? "granted" : "denied";
            window.gtag("consent", "update", {
              ad_storage: marketingStorage,
              analytics_storage: analyticsStorage,
              ad_user_data: marketingStorage,
              ad_personalization: marketingStorage,
              functionality_storage: "granted",
              security_storage: "granted"
            });
          }
        }
      } catch (_e) {}
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-TVDDSG65');
    </script>
    <!-- End Google Tag Manager -->

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.pexels.com" />
    <link rel="stylesheet" href="https://calendar.google.com/calendar/scheduling-button-script.css" />
    <script src="https://calendar.google.com/calendar/scheduling-button-script.js" async></script>
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500&display=swap"
      />
    </noscript>

    <script>document.documentElement.classList.add('js');</script>
    <script src="/scripts/cursor.js" defer></script>
    <script src="/scripts/theme.js" defer></script>
    <script src="/scripts/contact-overlay.js" defer></script>
    <script src="/scripts/tracking.js" defer></script>
    <script>
      import Lenis from 'lenis';
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(graphSchema)}></script>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TVDDSG65"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div id="page">
      <slot />
    </div>
    <ConsentBanner />
    <WhatsAppChat />
    <MobileBottomBar />
  </body>
</html>
